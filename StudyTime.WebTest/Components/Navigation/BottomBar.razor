@using Microsoft.AspNetCore.Components.Routing
@using StudyTime.DesktopClient.Services
@inject NavigationManager Nav
@inject AppNotificationCenterService NotificationService

<div class="bottom-bar">
    <nav class="bottom-nav">
        <NavLink class="bottom-nav-item" href="" Match="NavLinkMatch.All">
            <i class="bi bi-grid-fill"></i>
            <span>Panel</span>
        </NavLink>

        <NavLink class="bottom-nav-item" href="lessons">
            <i class="bi bi-book-half"></i>
            <span>Dersler</span>
        </NavLink>

        <div class="bottom-nav-action-wrapper">
            <button class="main-action-btn" @onclick='() => NotificationService.ToggleCenter()' title="Bildirimler ve Duyurular">
                <div class="action-btn-inner">
                    <i class="bi bi-bell-fill"></i>
                    @if (NotificationService.UnreadCount > 0)
                    {
                        <span class="action-badge">@NotificationService.UnreadCount</span>
                    }
                </div>
            </button>
        </div>

        <NavLink class="bottom-nav-item" href="tasks">
            <i class="bi bi-calendar-check-fill"></i>
            <span>Görevler</span>
        </NavLink>

        <NavLink class="bottom-nav-item" href="statistics">
            <i class="bi bi-bar-chart-line-fill"></i>
            <span>Analiz</span>
        </NavLink>
    </nav>
</div>

@code {
    
}

<style>
    .bottom-nav-action-wrapper {
        position: relative;
        top: -18px; /* Lift it up a bit */
        z-index: 100;
    }

    .main-action-btn {
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        outline: none;
    }

    .action-btn-inner {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
        box-shadow: 0 8px 20px rgba(37, 99, 235, 0.4), 0 0 0 5px var(--bg-app);
        transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .main-action-btn:active .action-btn-inner {
        transform: scale(0.9) translateY(4px);
        box-shadow: 0 4px 10px rgba(37, 99, 235, 0.3), 0 0 0 3px var(--bg-app);
    }

    .action-badge {
        position: absolute;
        top: 2px;
        right: 2px;
        min-width: 20px;
        height: 20px;
        background: #ef4444;
        color: white;
        font-size: 0.7rem;
        font-weight: 800;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #2563eb;
    }

    /* Active indicator glow */
    .bottom-nav-item.active i {
        text-shadow: 0 0 10px rgba(59, 130, 246, 0.5);
    }
</style>
