@inherits LayoutComponentBase
@inject StudyTime.DesktopClient.Services.IPlatformDetector PlatformDetector

@if (PlatformDetector.IsMobile)
{
    <StudyTime.WebTest.Components.Layout.MobileLayout>
        @Body
    </StudyTime.WebTest.Components.Layout.MobileLayout>
}
else
{
    <StudyTime.WebTest.Components.Layout.DesktopLayout>
        @Body
    </StudyTime.WebTest.Components.Layout.DesktopLayout>
}

