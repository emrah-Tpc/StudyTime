<div class="app-layout-container">
    <StudyTime.WebTest.Components.Layout.OfflineBanner />

    <div class="mobile-header-top">
        <StudyTime.WebTest.Components.Navigation.MobileHeader />
    </div>

    <!-- Mobil cihazlarda alt barda boşluk bırakmak için pb-5 eklendi (BottomBar yüksekliği kadar) -->
    <main class="main-content-scrollable pb-5">
        <div class="content-wrapper">
            @ChildContent
        </div>
    </main>

    <div class="mobile-nav">
        <StudyTime.WebTest.Components.Navigation.BottomBar />
    </div>
</div>

<!-- Global Modals & Overlays -->
<StudyTime.WebTest.Components.Layout.SyncIndicator />
<StudyTime.WebTest.Components.Layout.FocusMode />
<StudyTime.WebTest.Components.Navigation.NotificationCenter />

@code {
    [Parameter]
    public RenderFragment ChildContent { get; set; } = default!;
}
