@page "/workspace/{Id:guid}"
@page "/workspace"
@using StudyTime.Application.DTOs.Lessons
@using StudyTime.Application.DTOs.Tasks
@using StudyTime.DesktopClient.Services
@using StudyTime.DesktopClient.Offline
@using StudyTime.Domain.Enums
@implements IDisposable
@inject SyncedLessonApiService LessonService
@inject StudySessionApiService SessionApiService
@inject SyncedTaskApiService TaskApiService
@inject GlobalTimerService GlobalTimer
@inject NavigationManager Nav
@inject IJSRuntime JS

<style>
@@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@700;800&display=swap');

/* Root fills available space */
.wsp-root {
    display: flex;
    flex-direction: column;
    height: calc(100vh - var(--header-height, 64px));
    overflow: hidden;
    background: var(--bg-app);
    color: var(--text-main);
    position: relative;
}

/* ── Header: minimal & professional ── */
.wsp-header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    border-bottom: 1px solid var(--border-color);
    flex-shrink: 0;
    background: rgba(15,15,18,0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    min-height: 52px;
}
.wsp-back {
    text-decoration: none;
    display: flex; align-items: center; justify-content: center;
    width: 34px; height: 34px;
    border-radius: 10px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    color: #94a3b8;
    font-size: 1rem;
    transition: background 0.2s, color 0.2s;
    flex-shrink: 0;
}
.wsp-back:hover { background: rgba(255,255,255,0.1); color: white; }
[data-theme="light"] .wsp-back { background: rgba(0,0,0,0.05); border-color: rgba(0,0,0,0.1); color: #64748b; }
[data-theme="light"] .wsp-back:hover { background: rgba(0,0,0,0.1); color: #0f172a; }
.wsp-header-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 0;
}
.wsp-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
    text-align: center;
}
.wsp-badge {
    font-size: 0.6rem;
    padding: 2px 8px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 99px;
    color: #71717a;
    margin-top: 2px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
}
[data-theme="light"] .wsp-badge { background: rgba(0,0,0,0.05); border-color: rgba(0,0,0,0.08); color: #64748b; }

/* Center timer area */
.wsp-center {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 12px 16px 100px;
    min-height: 0;
    overflow-y: auto;
    scroll-behavior: smooth;
}
/* Custom mod açıkken içerik yukarıdan başlasın ve sıkışmadan sığsın */
.wsp-center.custom-active {
    gap: 8px;
    padding-top: 8px;
    justify-content: flex-start;
}

/* Status / active task */
.wsp-status { font-size:0.88rem; color:#94a3b8; text-align:center; }
.wsp-active-task { font-size:1rem; font-weight:700; text-align:center; animation:wFadeIn 0.4s ease; }

/* Presets */
.wsp-presets { display:flex; gap:8px; justify-content:center; flex-wrap:wrap; width:100%; }
.wsp-preset {
    display:flex; flex-direction:column; align-items:center;
    padding:8px 12px; gap:4px;
    background:rgba(255,255,255,0.03);
    border:1px solid var(--border-color);
    border-radius:12px; color:#71717a;
    transition:0.2s; cursor:pointer; min-width:64px; flex:1; max-width:88px;
}
.wsp-preset i { font-size:1rem; }
.wsp-preset span { font-size:0.65rem; font-weight:600; white-space:nowrap; }
.wsp-preset.active { border-color:var(--lesson-color,#3b82f6); color:var(--lesson-color,#3b82f6); background:rgba(59,130,246,0.06); }

/* Custom row */
.wsp-custom-row {
    display:flex; align-items:center; gap:12px;
    background:rgba(0,0,0,0.2); padding:6px 14px;
    border-radius:12px; border:1px solid var(--border-color);
    width:100%; max-width:300px;
}
.custom-field { text-align:center; flex:1; }
.custom-label { font-size:0.5rem; font-weight:800; color:#94a3b8; display:block; margin-bottom:2px; letter-spacing:0.08em; }
.custom-spin { display:flex; align-items:center; gap:6px; justify-content:center; }
.custom-spin button { background:#27272a; border:none; width:22px; height:22px; border-radius:6px; color:white; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:0.9rem; transition:0.15s; }
.custom-spin button:hover { background:#3f3f46; }
.custom-spin span { font-family:'JetBrains Mono'; font-weight:700; font-size:0.85rem; min-width:24px; text-align:center; }
.wsp-sep { width:1px; height:24px; background:rgba(255,255,255,0.12); flex-shrink:0; }

.wsp-break-badge { font-size:0.7rem; color:var(--lesson-color,#3b82f6); background:rgba(255,255,255,0.05); padding:3px 12px; border-radius:99px; border:1px solid rgba(255,255,255,0.07); }

/* Timer circle - mobilde küçültüldü */
.wsp-circle-wrap {
    position:relative;
    width:clamp(160px,42vw,240px);
    height:clamp(160px,42vw,240px);
    display:flex; align-items:center; justify-content:center;
    flex-shrink:0;
}
.wsp-svg { width:100%; height:100%; transform:rotate(-90deg); overflow:visible; }
.wsp-ring-bg { fill:none; stroke:rgba(255,255,255,0.05); stroke-width:7; }
.wsp-ring-fill { fill:none; stroke-width:9; stroke-linecap:round; transition:stroke-dashoffset 0.8s cubic-bezier(0.4,0,0.2,1); filter:drop-shadow(0 0 14px currentColor); }
.wsp-time { position:absolute; font-size:clamp(2.2rem,8vw,3.5rem); font-weight:800; font-family:'JetBrains Mono',monospace; color:white; letter-spacing:-2px; }

/* Controls */
.wsp-controls { display:flex; gap:10px; align-items:center; justify-content:center; }
.wsp-btn-main { padding:13px 36px; border-radius:99px; border:none; color:white; font-weight:800; font-size:0.9rem; display:flex; align-items:center; gap:8px; transition:0.25s; box-shadow:0 6px 20px rgba(0,0,0,0.4); cursor:pointer; }
.wsp-btn-main.start { background:var(--lesson-color,#3b82f6); }
.wsp-btn-main.pause { background:#f59e0b; }
.wsp-btn-main.resume { background:#10b981; }
.wsp-btn-stop { padding:13px 24px; border-radius:99px; background:rgba(255,255,255,0.06); border:1px solid #3f3f46; color:#ef4444; font-weight:700; font-size:0.85rem; transition:0.2s; cursor:pointer; }
.wsp-btn-stop:hover { background:rgba(239,68,68,0.12); border-color:#ef4444; }
.wsp-btn-focus { font-size:0.72rem; color:#94a3b8; background:transparent; border:1px solid rgba(255,255,255,0.08); padding:6px 18px; border-radius:99px; transition:0.2s; cursor:pointer; }
.wsp-btn-focus:hover { color:white; background:rgba(255,255,255,0.07); }

/* ── FLOATING PANEL BUTTONS (bottom corners, thumb-friendly) ── */
.wsp-fab-bar {
    position:absolute;
    bottom: calc(var(--bottom-bar-height, 70px) + 12px);
    left: 0; right: 0;
    display: flex;
    justify-content: space-between;
    padding: 0 20px;
    pointer-events: none;
    z-index: 50;
}
.wsp-fab {
    width: 52px; height: 52px;
    border-radius: 16px;
    background: rgba(24,24,27,0.95);
    border: 1px solid var(--border-color);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: var(--text-muted);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem;
    cursor: pointer;
    transition: 0.2s;
    pointer-events: all;
    box-shadow: 0 4px 16px rgba(0,0,0,0.4);
}
.wsp-fab:hover, .wsp-fab:active { color: white; border-color: var(--border-highlight); }
.wsp-fab.open { background: rgba(59,130,246,0.2); border-color: #3b82f6; color: #3b82f6; }

/* ── SLIDE-IN OVERLAY PANELS ── */
.wsp-overlay-panel {
    position: absolute;
    top: 0; bottom: 0;
    width: min(300px, 80vw);
    background: rgba(15,15,18,0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-color: var(--border-color);
    display: flex;
    flex-direction: column;
    z-index: 100;
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
    padding: 20px 16px;
    overflow-y: auto;
}
.wsp-overlay-panel.left  { left:0; border-right:1px solid var(--border-color); transform: translateX(-100%); }
.wsp-overlay-panel.right { right:0; border-left:1px solid var(--border-color); transform: translateX(100%); }
.wsp-overlay-panel.open  { transform: translateX(0); }

/* Backdrop */
.wsp-backdrop {
    position:absolute; inset:0; background:rgba(0,0,0,0.5);
    z-index:99; backdrop-filter:blur(2px);
    animation: wBackdrop 0.2s ease;
}
@@keyframes wBackdrop { from{opacity:0} to{opacity:1} }

.wsp-panel-title { font-size:0.72rem; text-transform:uppercase; letter-spacing:0.09em; color:var(--text-dim); font-weight:700; margin-bottom:14px; }

/* Task items */
.wsp-task-item {
    display:flex; align-items:center; gap:10px;
    padding:10px 12px; border-radius:12px;
    background:rgba(255,255,255,0.03); border:1px solid transparent;
    margin-bottom:8px; transition:0.15s;
}
.wsp-task-item:hover { background:rgba(255,255,255,0.05); border-color:var(--border-color); }
.wsp-task-item.active-task { border-color:var(--lesson-color,#3b82f6); background:rgba(59,130,246,0.08); }
.wsp-task-play { background:none; border:none; padding:4px; cursor:pointer; font-size:1.1rem; display:flex; align-items:center; flex-shrink:0; transition:opacity 0.15s; }
.wsp-task-play:hover { opacity:0.8; }
.wsp-task-title { flex:1; font-size:0.85rem; color:var(--text-main); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.wsp-task-check { background:none; border:none; color:#94a3b8; cursor:pointer; padding:6px; font-size:1rem; transition:0.15s; border-radius:6px; flex-shrink:0; }
.wsp-task-check:hover { color:#10b981; background:rgba(16,185,129,0.1); }

/* Add Task */
.wsp-add-task-btn {
    width:100%; display:flex; align-items:center; justify-content:center; gap:8px;
    padding:10px 12px; border-radius:12px; margin-top:8px;
    background:rgba(59,130,246,0.08); border:1px dashed rgba(59,130,246,0.3);
    color:#3b82f6; font-size:0.82rem; font-weight:600;
    cursor:pointer; transition:0.2s;
}
.wsp-add-task-btn:hover { background:rgba(59,130,246,0.14); border-color:rgba(59,130,246,0.5); }
.wsp-add-task-row {
    display:flex; align-items:center; gap:6px; margin-top:8px;
}
.wsp-add-task-input {
    flex:1; background:rgba(255,255,255,0.05); border:1px solid var(--border-color);
    border-radius:10px; padding:8px 12px; color:var(--text-main);
    font-size:0.85rem; outline:none; transition:border-color 0.2s;
}
.wsp-add-task-input:focus { border-color:rgba(59,130,246,0.5); }
.wsp-add-task-save {
    width:32px; height:32px; border-radius:8px; border:none;
    background:#3b82f6; color:white; cursor:pointer; display:flex; align-items:center; justify-content:center;
    font-size:1rem; flex-shrink:0; transition:0.15s;
}
.wsp-add-task-save:hover { background:#2563eb; }
.wsp-add-task-cancel {
    width:32px; height:32px; border-radius:8px; border:1px solid var(--border-color);
    background:transparent; color:#94a3b8; cursor:pointer; display:flex; align-items:center; justify-content:center;
    font-size:1.1rem; flex-shrink:0; transition:0.15s;
}
.wsp-add-task-cancel:hover { background:rgba(255,255,255,0.06); color:white; }

/* Note textarea */
.wsp-note { background:rgba(0,0,0,0.35); border:1px solid var(--border-color); border-radius:12px; padding:14px; color:#d1d5db; font-size:0.875rem; resize:none; outline:none; width:100%; flex:1; min-height:180px; transition:border-color 0.2s; line-height:1.6; }
.wsp-note:focus { border-color:rgba(255,255,255,0.2); }
.wsp-autosave { font-size:0.65rem; color:#22c55e; text-align:right; margin-top:8px; height:16px; transition:opacity 0.3s; }

/* Conflict overlay */
.wsp-conflict { position:absolute; inset:0; background:rgba(9,9,11,0.97); display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:30px; z-index:200; }
.wsp-conflict-btn { background:var(--accent-blue,#3b82f6); color:white; padding:13px 32px; border-radius:99px; font-weight:800; text-decoration:none; transition:0.2s; box-shadow:0 8px 20px rgba(59,130,246,0.3); }
.wsp-conflict-btn:hover { transform:translateY(-3px); }

/* Desktop adjustments */
@@media (min-width: 768px) {
    .wsp-fab-bar { bottom: 20px; }
    .wsp-center { padding-bottom: 90px; }
}

@@keyframes wFadeIn { from{opacity:0;transform:translateY(4px)} to{opacity:1;transform:translateY(0)} }

/* ── Task full form ──────────────────────── */
.wsp-task-form {
    background: rgba(15,15,18,0.98);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 100%;
    margin-top: 8px;
}
.wsp-task-form-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-blue, #3b82f6);
    margin-bottom: 2px;
}
.wsp-form-row { display:flex; gap:8px; }
.wsp-form-group { display:flex; flex-direction:column; gap:4px; flex:1; min-width:0; }
.wsp-form-label { font-size:0.62rem; font-weight:600; color:#71717a; text-transform:uppercase; letter-spacing:0.05em; }
.wsp-form-input {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 8px 10px;
    color: var(--text-main);
    font-size: 0.82rem;
    outline: none;
    width: 100%;
    transition: border-color 0.2s;
    font-family: inherit;
}
.wsp-form-input:focus { border-color: rgba(59,130,246,0.5); }
.wsp-form-textarea { min-height: 60px; resize: none; line-height: 1.5; }
.wsp-form-input[type="date"] { color-scheme: dark; }
.wsp-form-actions { display:flex; gap:8px; margin-top:4px; }
.wsp-form-btn-cancel {
    flex:1; padding:9px; border-radius:10px;
    background:transparent; border:1px solid var(--border-color);
    color:#71717a; font-size:0.82rem; cursor:pointer; transition:0.15s;
}
.wsp-form-btn-cancel:hover { background:rgba(255,255,255,0.05); color:var(--text-main); }
.wsp-form-btn-save {
    flex:2; padding:9px; border-radius:10px;
    background:var(--accent-blue,#3b82f6); border:none;
    color:white; font-size:0.82rem; font-weight:700; cursor:pointer; transition:0.15s;
    display:flex; align-items:center; justify-content:center; gap:6px;
}
.wsp-form-btn-save:hover { background:#2563eb; }
</style>

@if (isLoading)
{
    <div style="display:flex;align-items:center;justify-content:center;height:100%;background:var(--bg-app);">
        <div class="spinner-border text-primary"></div>
    </div>
}
else if (workspace != null)
{
    <div class="wsp-root fade-in" style="--lesson-color:@workspace.Color">

        <!-- Header: minimal & professional -->
        <div class="wsp-header">
            <a href="lessons" class="wsp-back" title="Geri">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div class="wsp-header-center">
                <h2 class="wsp-title" style="color:@workspace.Color">@workspace.Name</h2>
                <span class="wsp-badge">Çalışma Odası</span>
            </div>
            <div style="width:34px;"></div>
        </div>

        <!-- Backdrop when panel open -->
        @if (tasksOpen || notesOpen)
        {
            <div class="wsp-backdrop" @onclick="CloseAll"></div>
        }

        <!-- Left: Tasks overlay panel -->
        <div class="wsp-overlay-panel left @(tasksOpen ? "open" : "")">
            <div class="wsp-panel-title">📋 Görevler</div>

            @foreach (var task in workspace.Tasks.Where(t => !t.IsCompleted))
            {
                <div class="wsp-task-item @(activeTaskId == task.Id ? "active-task" : "")">
                    <button class="wsp-task-play" @onclick="() => SelectTask(task.Id)" title="Başlat">
                        <i class="bi @(activeTaskId == task.Id && GlobalTimer.IsRunning ? "bi-pause-circle-fill" : "bi-play-circle")" style="color:var(--lesson-color,#3b82f6)"></i>
                    </button>
                    <span class="wsp-task-title">@task.Title</span>
                    <button class="wsp-task-check" @onclick="() => ToggleTaskStatus(task)" @onclick:stopPropagation="true" @ontouchstart:stopPropagation="true" title="Tamamla">
                        <i class="bi @(task.IsCompleted ? "bi-check2" : "bi-square")"></i>
                    </button>
                </div>
            }

            @if (!workspace.Tasks.Any(t => !t.IsCompleted))
            {
                <div style="text-align:center;color:var(--text-dim);font-size:0.8rem;padding:20px 0;">
                    <i class="bi bi-check-all d-block mb-2" style="font-size:1.8rem;color:#10b981;"></i>
                    Tüm görevler tamamlandı!
                </div>
            }

            <!-- Görev Ekle -->
            @if (addingTask)
            {
                <div class="wsp-task-form">
                    <div class="wsp-task-form-title">Yeni Görev</div>

                    <input class="wsp-form-input" @bind="newTaskTitle" @bind:event="oninput"
                           placeholder="Görev adı *" @onkeydown="OnAddTaskKeyDown" />

                    <div class="wsp-form-row">
                        <div class="wsp-form-group">
                            <label class="wsp-form-label">Başlangıç</label>
                            <input type="date" class="wsp-form-input" @bind="newTaskStartDate" />
                        </div>
                        <div class="wsp-form-group">
                            <label class="wsp-form-label">Bitiş</label>
                            <input type="date" class="wsp-form-input" @bind="newTaskEndDate" />
                        </div>
                    </div>

                    <div class="wsp-form-group">
                        <label class="wsp-form-label">Hedef Süre (dk)</label>
                        <input type="number" class="wsp-form-input" @bind="newTaskDuration"
                               min="0" max="600" placeholder="Örn: 60" />
                    </div>

                    <textarea class="wsp-form-input wsp-form-textarea"
                              @bind="newTaskNote" @bind:event="oninput" maxlength="400" placeholder="Açıklama (isteğe bağlı)"></textarea>
                    <div class="text-end small mb-2" style="color:var(--text-dim); margin-top:-10px;">@(newTaskNote?.Length ?? 0)/400</div>

                    <div class="wsp-form-actions">
                        <button class="wsp-form-btn-cancel" @onclick="CancelAddTask" disabled="@isSubmittingTask">İptal</button>
                        <button class="wsp-form-btn-save" @onclick="SaveNewTask" disabled="@isSubmittingTask">
                            @if (isSubmittingTask)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Ekleniyor...</span>
                            }
                            else
                            {
                                <i class="bi bi-check-lg"></i> <span>Ekle</span>
                            }
                        </button>
                    </div>
                </div>
            }
            else
            {
                <button class="wsp-add-task-btn" @onclick="() => addingTask = true">
                    <i class="bi bi-plus-lg"></i>
                    <span>Görev Ekle</span>
                </button>
            }
        </div>

        <!-- Right: Notes overlay panel -->
        <div class="wsp-overlay-panel right @(notesOpen ? "open" : "")" style="display:flex;flex-direction:column;">
            <div class="wsp-panel-title">📝 Notlar</div>
            <textarea class="wsp-note" @bind="noteContent" @oninput="OnNoteInput" placeholder="Düşüncelerini yaz..."></textarea>
            <div class="wsp-autosave" style="opacity:@(isSaving ? 1 : 0)">
                <i class="bi bi-check-circle-fill me-1"></i>Kaydedildi
            </div>
        </div>

        <!-- CENTER: Timer (always full width, never pushed) -->
        <div class="wsp-center @(isCustomMode ? "custom-active" : "")">

            <!-- Conflict overlay -->
            @if (GlobalTimer.IsRunning && GlobalTimer.ActiveLessonId != Id)
            {
                <div class="wsp-conflict">
                    <i class="bi bi-clock-history mb-4" style="font-size:3rem;color:@GlobalTimer.ActiveColor"></i>
                    <h4 class="text-white fw-black mb-2">OTURUM ÇAKIŞMASI</h4>
                    <p class="text-muted small px-4 mb-4">Başka bir derste aktif oturum var. Önce onu bitir.</p>
                    <a href="workspace/@GlobalTimer.ActiveLessonId" class="wsp-conflict-btn">AKTİF OTURUMA GİT</a>
                </div>
            }

            @if (activeTaskId != null)
            {
                var t = workspace.Tasks.FirstOrDefault(x => x.Id == activeTaskId);
                <div class="wsp-active-task" style="color:@workspace.Color">
                    <i class="bi bi-bookmark-fill me-2"></i>@t?.Title
                </div>
            }
            else
            {
                <div class="wsp-status">@(GlobalTimer.IsRunning ? (GlobalTimer.IsBreak ? "Mola Veriliyor ☕" : "Odaklanılıyor...") : "Bir mod seç ve başlat")</div>
            }

            <!-- Mode presets -->
            <div class="wsp-presets">
                <button class="wsp-preset @(selectedMode==0&&!isCustomMode?"active":"")" @onclick='()=>SelectPreset(0,0)'>
                    <i class="bi bi-infinity"></i><span>Serbest</span>
                </button>
                <button class="wsp-preset @(selectedMode==25?"active":"")" @onclick='()=>SelectPreset(25,5)'>
                    <i class="bi bi-clock"></i><span>Klasik 25+5</span>
                </button>
                <button class="wsp-preset @(selectedMode==50?"active":"")" @onclick='()=>SelectPreset(50,10)'>
                    <i class="bi bi-bullseye"></i><span>Derin 50+10</span>
                </button>
                <button class="wsp-preset @(isCustomMode?"active":"")" @onclick='()=>SelectPreset(-1,customBreakMin)'>
                    <i class="bi bi-sliders"></i><span>Özel</span>
                </button>
            </div>

            @if (isCustomMode)
            {
                <div class="wsp-custom-row">
                    <div class="custom-field">
                        <span class="custom-label">ÇALIŞMA (dk)</span>
                        <div class="custom-spin">
                            <button @onclick='()=>{if(customWorkMin>5)customWorkMin-=5;}'>−</button>
                            <span>@customWorkMin</span>
                            <button @onclick='()=>{if(customWorkMin<120)customWorkMin+=5;}'>+</button>
                        </div>
                    </div>
                    <div class="wsp-sep"></div>
                    <div class="custom-field">
                        <span class="custom-label">MOLA (dk)</span>
                        <div class="custom-spin">
                            <button @onclick='()=>{if(customBreakMin>1)customBreakMin-=1;}'>−</button>
                            <span>@customBreakMin</span>
                            <button @onclick='()=>{if(customBreakMin<30)customBreakMin+=1;}'>+</button>
                        </div>
                    </div>
                </div>
            }

            @if (selectedMode > 0 || isCustomMode)
            {
                <div class="wsp-break-badge"><i class="bi bi-cup-hot me-1"></i>Mola: @(isCustomMode ? customBreakMin : (selectedMode==25?5:10)) dk</div>
            }

            <!-- Timer circle -->
            <div class="wsp-circle-wrap">
                <svg class="wsp-svg" viewBox="0 0 200 200">
                    <circle cx="100" cy="100" r="90" class="wsp-ring-bg" />
                    <circle cx="100" cy="100" r="90" class="wsp-ring-fill"
                            style="stroke:@(GlobalTimer.IsBreak?"#10b981":workspace.Color);stroke-dasharray:565;stroke-dashoffset:@timerDashOffset;color:@(GlobalTimer.IsBreak?"#10b981":workspace.Color)" />
                </svg>
                <div class="wsp-time">@DisplayTime.ToString(DisplayTime.TotalHours>=1?@"hh\:mm\:ss":@"mm\:ss")</div>
            </div>

            <!-- Controls -->
            <div class="wsp-controls">
                @if (!GlobalTimer.IsRunning && !GlobalTimer.IsPaused)
                {
                    <button class="wsp-btn-main start" @onclick="StartTimer" disabled="@isTimerActionRunning">
                        @if (isTimerActionRunning)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        else
                        {
                            <i class="bi bi-play-fill"></i>
                        }
                        BAŞLAT
                    </button>
                }
                else if (GlobalTimer.IsPaused && GlobalTimer.ActiveLessonId == Id)
                {
                    <div class="d-flex justify-content-center gap-3">
                        <button class="wsp-btn-main resume flex-grow-1" @onclick="() => GlobalTimer.Resume()" disabled="@isTimerActionRunning"><i class="bi bi-play-fill"></i> DEVAM ET</button>
                        <button class="wsp-btn-main stop" @onclick="StopTimer" disabled="@isTimerActionRunning">
                            @if (isTimerActionRunning)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            else
                            {
                                <i class="bi bi-stop-fill"></i>
                            }
                        </button>
                    </div>
                }
                else if (GlobalTimer.IsRunning && GlobalTimer.ActiveLessonId == Id)
                {
                    <div class="d-flex justify-content-center gap-3">
                        <button class="wsp-btn-main pause flex-grow-1" @onclick="() => GlobalTimer.Pause()" disabled="@isTimerActionRunning"><i class="bi bi-pause-fill"></i> DURAKLAT</button>
                        <button class="wsp-btn-main stop" @onclick="StopTimer" disabled="@isTimerActionRunning">
                            @if (isTimerActionRunning)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            else
                            {
                                <i class="bi bi-stop-fill"></i>
                            }
                        </button>
                    </div>
                }
            </div>

            @if (GlobalTimer.IsRunning && !GlobalTimer.IsBreak && GlobalTimer.ActiveLessonId == Id)
            {
                <button class="wsp-btn-focus" @onclick="EnterFocusMode"><i class="bi bi-fullscreen me-2"></i>TAM EKRAN ODAK</button>
            }
        </div>

        <!-- FAB buttons — bottom corners, thumb-reachable -->
        <div class="wsp-fab-bar">
            <button class="wsp-fab @(tasksOpen?"open":"")" @onclick="ToggleTasks" title="Görevler">
                <i class="bi bi-list-check"></i>
            </button>
            <button class="wsp-fab @(notesOpen?"open":"")" @onclick="ToggleNotes" title="Notlar">
                <i class="bi bi-pencil-square"></i>
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private WorkspaceDetailDto? workspace;
    private bool isLoading = true;
    private Guid? activeTaskId = null;
    private double timerDashOffset = 0;
    private const double CIRCUMFERENCE = 565;
    private int selectedMode = 0;
    private bool isCustomMode = false;
    private int customWorkMin = 25;
    private int customBreakMin = 5;
    private string noteContent = "";
    private bool isSaving = false;
    private bool isSubmittingTask = false;
    private bool isTimerActionRunning = false;
    private bool tasksOpen = false;
    private bool notesOpen = false;
    private bool addingTask = false;
    private string newTaskTitle = "";
    private DateTime? newTaskStartDate = null;
    private DateTime? newTaskEndDate = null;
    private int? newTaskDuration = null;
    private string newTaskNote = "";
    private System.Timers.Timer? _debounceTimer;

    private TimeSpan DisplayTime => (GlobalTimer.IsRunning || GlobalTimer.IsPaused)
        ? (GlobalTimer.IsCountdown ? GlobalTimer.RemainingTime : GlobalTimer.ElapsedTime)
        : PreviewTime;

    private TimeSpan PreviewTime => isCustomMode
        ? TimeSpan.FromMinutes(customWorkMin)
        : (selectedMode == 0 ? TimeSpan.Zero : TimeSpan.FromMinutes(selectedMode));

    protected override void OnInitialized()
    {
        GlobalTimer.OnTick += OnTimerTick;
        GlobalTimer.OnTimerFinished += OnTimerFinished;
        _debounceTimer = new System.Timers.Timer(1500) { AutoReset = false };
        _debounceTimer.Elapsed += async (s, e) => await SaveNotesAuto();
    }

    protected override async Task OnParametersSetAsync() => await LoadData();

    private async Task LoadData()
    {
        workspace = await LessonService.GetWorkspaceDetailAsync(Id);
        if (workspace != null)
        {
            noteContent = workspace.Note ?? "";
            if (GlobalTimer.ActiveLessonId == Id) activeTaskId = GlobalTimer.ActiveTaskId;
        }
        isLoading = false;
    }

    private void ToggleTasks() { tasksOpen = !tasksOpen; if (tasksOpen) notesOpen = false; }
    private void ToggleNotes() { notesOpen = !notesOpen; if (notesOpen) tasksOpen = false; }
    private void CloseAll() { tasksOpen = false; notesOpen = false; addingTask = false; newTaskTitle = ""; }
    private void CancelAddTask()
    {
        addingTask = false;
        newTaskTitle = "";
        newTaskStartDate = null;
        newTaskEndDate = null;
        newTaskDuration = null;
        newTaskNote = "";
    }

    private async Task SaveNewTask()
    {
        if (string.IsNullOrWhiteSpace(newTaskTitle) || workspace == null || isSubmittingTask) return;
        isSubmittingTask = true;
        StateHasChanged();
        
        try
        {
            var dto = new CreateTaskDto
            {
                Title = newTaskTitle.Trim(),
                LessonId = Id,
                StartDate = newTaskStartDate,
                EndDate = newTaskEndDate,
                PlannedDurationMinutes = newTaskDuration,
                Note = string.IsNullOrWhiteSpace(newTaskNote) ? null : newTaskNote.Trim(),
                Status = StudyTime.Domain.Enums.TaskStatus.Pending
            };
            await TaskApiService.CreateAsync(dto);
            CancelAddTask();
            workspace = await LessonService.GetWorkspaceDetailAsync(Id);
        }
        finally
        {
            isSubmittingTask = false;
            StateHasChanged();
        }
    }

    private async Task OnAddTaskKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(newTaskTitle)) await SaveNewTask();
        else if (e.Key == "Escape") CancelAddTask();
    }

    private async Task SelectTask(Guid taskId)
    {
        if (GlobalTimer.IsRunning && GlobalTimer.ActiveLessonId != Id) return;
        activeTaskId = taskId;
        tasksOpen = false;
        if (!GlobalTimer.IsRunning) await StartTimer();
    }

    private async Task StartTimer()
    {
        if (isTimerActionRunning) return;
        if (GlobalTimer.IsRunning && GlobalTimer.ActiveLessonId != Id) return;
        
        isTimerActionRunning = true;
        StateHasChanged();

        try
        {
            var color = workspace?.Color ?? "#3b82f6";
            int workMin = isCustomMode ? customWorkMin : selectedMode;
            int breakMin = isCustomMode ? customBreakMin : (selectedMode == 25 ? 5 : 10);
            TimeSpan? countdown = workMin > 0 ? TimeSpan.FromMinutes(workMin) : null;
            TimeSpan? breakSpan = workMin > 0 && breakMin > 0 ? TimeSpan.FromMinutes(breakMin) : null;
            string? taskTitle = activeTaskId.HasValue ? workspace?.Tasks.FirstOrDefault(t => t.Id == activeTaskId)?.Title : null;
            await GlobalTimer.StartAsync(Id, activeTaskId, color, taskTitle: taskTitle, countdown: countdown, breakDuration: breakSpan);
        }
        finally
        {
            isTimerActionRunning = false;
            StateHasChanged();
        }
    }

    private async Task StopTimer()
    {
        if (isTimerActionRunning) return;
        isTimerActionRunning = true;
        StateHasChanged();

        try
        {
            await GlobalTimer.StopAsync();
        }
        finally
        {
            isTimerActionRunning = false;
            StateHasChanged();
        }
    }

    private async void OnTimerFinished()
    {
        if (GlobalTimer.BreakDuration.TotalSeconds > 0)
        {
            await GlobalTimer.StartBreakAsync();
        }
    }

    private void SelectPreset(int workMin, int breakMin)
    {
        if (workMin == -1) { isCustomMode = true; selectedMode = 0; }
        else { isCustomMode = false; selectedMode = workMin; }
    }

    private void OnTimerTick()
    {
        if (GlobalTimer.ActiveLessonId == Id) CalculateProgress();
        InvokeAsync(StateHasChanged);
    }

    private void CalculateProgress()
    {
        if (GlobalTimer.IsCountdown && GlobalTimer.InitialDuration.TotalSeconds > 0)
            timerDashOffset = CIRCUMFERENCE * (1 - GlobalTimer.RemainingTime.TotalSeconds / GlobalTimer.InitialDuration.TotalSeconds);
        else
            timerDashOffset = CIRCUMFERENCE * ((GlobalTimer.ElapsedTime.TotalSeconds % 3600) / 3600.0);
    }

    private void EnterFocusMode() => GlobalTimer.SetFocusMode(true);

    private async Task ToggleTaskStatus(TaskListItemDto task)
    {
        task.IsCompleted = !task.IsCompleted;
        await TaskApiService.UpdateTaskStatusAsync(task.Id, task.IsCompleted
            ? StudyTime.Domain.Enums.TaskStatus.Completed
            : StudyTime.Domain.Enums.TaskStatus.Pending);
    }

    private void OnNoteInput(ChangeEventArgs e)
    {
        noteContent = e.Value?.ToString() ?? "";
        _debounceTimer?.Stop();
        _debounceTimer?.Start();
    }

    private async Task SaveNotesAuto()
    {
        if (workspace == null) return;
        isSaving = true;
        await InvokeAsync(StateHasChanged);
        await LessonService.UpdateNotesAsync(Id, noteContent);
        await Task.Delay(2000);
        isSaving = false;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        GlobalTimer.OnTick -= OnTimerTick;
        GlobalTimer.OnTimerFinished -= OnTimerFinished;
        _debounceTimer?.Dispose();
    }
}
