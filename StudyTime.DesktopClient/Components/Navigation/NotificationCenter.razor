@using StudyTime.DesktopClient.Services
@implements IDisposable
@inject AppNotificationCenterService NotificationService

@if (NotificationService.IsCenterOpen)
{
    <div class="nc-global-container">
        <!-- Overlay/Backdrop -->
        <div class="nc-overlay" @onclick="Close"></div>

        <!-- Centered Modal Content -->
        <div class="notification-center" @onclick:stopPropagation="true">
            <div class="nc-header">
                <div class="nc-title">
                    <i class="bi bi-bell-fill me-2"></i>Bildirimler
                    @if (NotificationService.UnreadCount > 0)
                    {
                        <span class="unread-badge">@NotificationService.UnreadCount</span>
                    }
                </div>
                <div class="nc-actions">
                    @if (NotificationService.UnreadCount > 0)
                    {
                        <button class="nc-btn-link" @onclick="MarkAllRead">Hepsini Oku</button>
                    }
                    <button class="nc-btn-close" @onclick="Close"><i class="bi bi-x"></i></button>
                </div>
            </div>

            <div class="nc-body">
                @if (!NotificationService.Notifications.Any())
                {
                    <div class="nc-empty">
                        <i class="bi bi-chat-dots opacity-25" style="font-size: 3rem;"></i>
                        <p>Henüz bildirim yok</p>
                    </div>
                }
                else
                {
                    @foreach (var note in NotificationService.Notifications)
                    {
                        <div class="nc-item @(note.IsRead ? "read" : "unread")" @onclick="() => HandleClick(note)">
                            <div class="nc-icon" style="background-color: @(note.Color)20; color: @note.Color;">
                                <i class="bi @note.Icon"></i>
                            </div>
                            <div class="nc-content">
                                <div class="nc-item-header">
                                    <span class="nc-item-title">@note.Title</span>
                                    <span class="nc-item-time">@GetRelativeTime(note.CreatedAt)</span>
                                </div>
                                <p class="nc-item-msg">@note.Message</p>
                            </div>
                            @if (!note.IsRead)
                            {
                                <div class="nc-read-dot"></div>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

<style>
    .nc-global-container {
        position: fixed;
        inset: 0;
        z-index: 99999;
        pointer-events: auto;
    }

    .nc-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.4); /* Daha hafif arka plan */
        backdrop-filter: blur(2px);
        z-index: -1;
    }

    .notification-center {
        position: absolute;
        top: 70px;
        right: 20px;
        width: 380px;
        max-height: 80vh;
        background: #1c1c1f;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 16px;
        box-shadow: 0 15px 50px rgba(0,0,0,0.6);
        display: flex;
        flex-direction: column;
        animation: ncSlideDown 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        overflow: hidden;
    }

    @@keyframes ncSlideDown {
        from { opacity: 0; transform: translateY(-15px) scale(0.98); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .nc-header {
        padding: 16px 20px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .nc-title {
        color: #fff;
        font-weight: 700;
        display: flex;
        align-items: center;
    }

    .unread-badge {
        background: #ef4444;
        color: #fff;
        font-size: 0.65rem;
        padding: 2px 6px;
        border-radius: 999px;
        margin-left: 8px;
    }

    .nc-actions {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .nc-btn-link {
        background: none;
        border: none;
        color: #3b82f6;
        font-size: 0.75rem;
        font-weight: 600;
        cursor: pointer;
        padding: 0;
    }

    .nc-btn-link:hover { text-decoration: underline; }

    .nc-btn-close {
        background: rgba(255,255,255,0.05);
        border: none;
        color: #fff;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    .nc-body {
        flex: 1;
        overflow-y: auto;
        padding: 8px 0;
    }

    .nc-empty {
        padding: 40px 20px;
        text-align: center;
        color: rgba(255,255,255,0.3);
    }

    .nc-empty p { margin-top: 12px; font-size: 0.85rem; }

    .nc-item {
        padding: 12px 20px;
        display: flex;
        gap: 14px;
        cursor: pointer;
        transition: background 0.2s;
        position: relative;
    }

    .nc-item:hover { background: rgba(255,255,255,0.03); }

    .nc-item.unread { background: rgba(59,130,246,0.03); }

    .nc-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .nc-content { flex: 1; min-width: 0; }

    .nc-item-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 2px;
    }

    .nc-item-title {
        color: #fff;
        font-size: 0.85rem;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .nc-item-time {
        font-size: 0.65rem;
        color: rgba(255,255,255,0.4);
    }

    .nc-item-msg {
        color: rgba(255,255,255,0.6);
        font-size: 0.78rem;
        margin: 0;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .nc-read-dot {
        position: absolute;
        top: 20px;
        right: 12px;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #3b82f6;
    }

    /* Custom Scrollbar */
    .nc-body::-webkit-scrollbar { width: 4px; }
    .nc-body::-webkit-scrollbar-track { background: transparent; }
    .nc-body::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
</style>

@code {
    protected override void OnInitialized()
    {
        NotificationService.OnNotificationsChanged += Refresh;
        NotificationService.OnCenterStateChanged += Refresh;
    }

    private void Refresh() => InvokeAsync(StateHasChanged);

    private void Close()
    {
        NotificationService.CloseCenter();
    }

    private void MarkAllRead()
    {
        NotificationService.MarkAllAsReadAsync();
    }

    private void HandleClick(AppNotification note)
    {
        NotificationService.MarkAsRead(note.Id);
        // If actionUrl exists, navigate to it (optional implementation)
    }

    private string GetRelativeTime(DateTime time)
    {
        var diff = DateTime.Now - time;
        if (diff.TotalMinutes < 1) return "Şimdi";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}dk önce";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}s önce";
        return time.ToString("dd MMM");
    }

    public void Dispose()
    {
        NotificationService.OnCenterStateChanged -= Refresh;
        NotificationService.OnNotificationsChanged -= Refresh;
    }
}
