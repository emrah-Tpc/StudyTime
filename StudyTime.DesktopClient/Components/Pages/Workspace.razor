@page "/workspace/{Id:guid}"
@using StudyTime.Application.DTOs.Lessons
@using StudyTime.Application.DTOs.Tasks
@using StudyTime.DesktopClient.Services
@using StudyTime.Domain.Enums
@implements IDisposable

@inject LessonApiService LessonService
@inject StudySessionApiService SessionApiService
@inject TaskApiService TaskApiService
@inject GlobalTimerService GlobalTimer
@inject NavigationManager Navigation

<div class="workspace-container fade-in">
    @if (isLoading)
    {
        <div class="d-flex justify-content-center align-items-center h-100">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else if (workspace != null)
    {
        <div class="ws-header mb-4">
            <a href="lessons" class="btn-back"><i class="bi bi-arrow-left"></i> Geri</a>
            <h2 class="m-0 fw-bold" style="color: @workspace.Color">@workspace.Name</h2>
            <span class="badge-soft text-muted">Çalışma Odası</span>
        </div>

        <div class="ws-grid">

            <div class="ws-card task-panel">
                <div class="panel-header">
                    <h5>Görevler</h5>
                    <button class="btn-icon-xs" @onclick="() => showAddTask = !showAddTask">
                        <i class="bi @(showAddTask ? "bi-x-lg" : "bi-plus-lg")"></i>
                    </button>
                </div>

                @if (showAddTask)
                {
                    <div class="task-creation-form mb-3 fade-in p-3" style="background: rgba(255,255,255,0.05); border-radius: 12px; border: 1px solid rgba(255,255,255,0.1);">
                        <div class="mb-2">
                            <label class="text-white small mb-1 opacity-75">Görev Adı</label>
                            <input type="text" class="form-control custom-input" placeholder="Örn: Matematik çalış..." @bind="newTask.Title" />
                        </div>
                        
                        <div class="row g-2 mb-2">
                             <div class="col-6">
                                <label class="text-white small mb-1 opacity-75">Başlangıç</label>
                                <input type="datetime-local" class="form-control custom-input" @bind="newTask.StartDate" />
                             </div>
                             <div class="col-6">
                                <label class="text-white small mb-1 opacity-75">Bitiş</label>
                                <input type="datetime-local" class="form-control custom-input" @bind="newTask.EndDate" />
                             </div>
                        </div>

                        <div class="mb-2">
                             <label class="text-white small mb-1 opacity-75">Tahmini Süre (Dk)</label>
                             <input type="number" class="form-control custom-input" placeholder="45" @bind="newTask.PlannedDurationMinutes" />
                        </div>

                        <div class="mb-3">
                             <label class="text-white small mb-1 opacity-75">Not</label>
                             <textarea class="form-control custom-input" rows="2" placeholder="Detaylar..." @bind="newTask.Note"></textarea>
                        </div>

                        <button class="btn-add-task w-100 py-2 fw-bold" 
                                style="background: linear-gradient(135deg, @workspace.Color, #3b82f6); border:none; border-radius:8px; color:white;"
                                @onclick="AddNewTask">
                            <i class="bi bi-plus-circle-fill me-2"></i> GÖREVİ OLUŞTUR
                        </button>
                    </div>
                }

                <div class="task-list-scroll">
                    @if (workspace.Tasks.Any())
                    {
                        var visibleTasks = workspace.Tasks.Where(t => !t.IsCompleted).ToList();
                        
                        @if (visibleTasks.Any()) 
                        {
                            @foreach (var task in visibleTasks)
                            {
                                <div class="ws-task-item @(activeTaskId == task.Id ? "active-task" : "")"
                                     style="--accent-color: @workspace.Color">
    
                                    <div class="d-flex align-items-center gap-2" style="flex: 1; overflow: hidden;">
                                        <input type="checkbox" class="form-check-input custom-check" 
                                               checked="@task.IsCompleted" 
                                               @onchange="@(async (e) => await ToggleTaskStatus(task))"
                                               style="cursor: pointer; flex-shrink: 0;" />
                                        
                                        <div class="d-flex align-items-baseline gap-2 text-truncate">
                                            <span class="@(task.IsCompleted ? "text-decoration-line-through text-muted" : "text-white") fw-medium">
                                                @task.Title
                                            </span>
                                            @if (!string.IsNullOrEmpty(task.Note))
                                            {
                                                <span class="text-white opacity-50 small text-truncate" style="max-width: 150px;" title="@task.Note">
                                                    - @task.Note
                                                </span>
                                            }
                                        </div>
                                    </div>
    
                                    <button class="btn-play-task" @onclick="() => SelectTask(task.Id)">
                                        @if (activeTaskId == task.Id && isTimerRunning)
                                        {
                                            <i class="bi bi-pause-fill"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-play-fill"></i>
                                        }
                                    </button>
                                </div>
                            }
                        }
                        else 
                        {
                             <div class="text-center text-muted py-4 small">Tüm görevler tamamlandı! 🎉</div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-4 small">Henüz görev yok.</div>
                    }
                </div>
            </div>

            <div class="ws-card timer-panel d-flex flex-column align-items-center justify-content-center">
                <div class="current-task-display mb-4">
                    @if (activeTaskId != null)
                    {
                        var t = workspace.Tasks.FirstOrDefault(x => x.Id == activeTaskId);
                        <span class="text-muted small">Şu an çalışılıyor:</span>
                        <div class="fw-bold text-white">@t?.Title</div>
                    }
                    else if (GlobalTimer.IsRunning || GlobalTimer.IsPaused)
                    {
                        <span class="text-muted small">
                            @(GlobalTimer.IsBreak ? "☕ Mola Vakti" : GlobalTimer.IsCountdown ? "Odaklanma Modu" : "Serbest Çalışma Modu")
                        </span>
                    }
                    else if (selectedMode > 0 || isCustomMode)
                    {
                        <span class="text-muted small">
                            @(isCustomMode ? $"Özel: {customWorkMin} dk + {customBreakMin} dk mola" : selectedMode == 25 ? "Klasik Pomodoro" : "Derin Odak")
                        </span>
                    }
                    else
                    {
                        <span class="text-muted small">Çalışma modu seç veya başlat</span>
                    }
                </div>

                @if (!isTimerRunning && !GlobalTimer.IsPaused)
                {
                    <!-- PRESET BUTTONS -->
                    <div class="timer-preset-row mb-2">
                        <button class="btn-preset @(selectedMode == 0 && !isCustomMode ? "active" : "")" @onclick='() => SelectPreset(0, 0)'>
                            <i class="bi bi-infinity"></i>
                            <span>Serbest</span>
                        </button>
                        <button class="btn-preset @(selectedMode == 25 ? "active" : "")" @onclick='() => SelectPreset(25, 5)'>
                            <i class="bi bi-clock"></i>
                            <span>Klasik</span>
                            <small class="preset-sub">25 + 5</small>
                        </button>
                        <button class="btn-preset @(selectedMode == 50 ? "active" : "")" @onclick='() => SelectPreset(50, 10)'>
                            <i class="bi bi-bullseye"></i>
                            <span>Derin Odak</span>
                            <small class="preset-sub">50 + 10</small>
                        </button>
                        <button class="btn-preset @(isCustomMode ? "active" : "")" @onclick='() => SelectPreset(-1, customBreakMin)'>
                            <i class="bi bi-sliders"></i>
                            <span>Özel</span>
                        </button>
                    </div>

                    @if (isCustomMode)
                    {
                        <!-- CUSTOM MODE INPUTS: spinner buttons do NOT close the panel -->
                        <div class="custom-mode-row mb-3">
                            <div class="custom-field">
                                <label class="custom-label">Çalışma</label>
                                <div class="custom-spin">
                                    <button @onclick='() => { if(customWorkMin > 5) customWorkMin -= 5; }'>−</button>
                                    <span>@customWorkMin dk</span>
                                    <button @onclick='() => { if(customWorkMin < 120) customWorkMin += 5; }'>+</button>
                                </div>
                            </div>
                            <div class="custom-divider">+</div>
                            <div class="custom-field">
                                <label class="custom-label">Mola</label>
                                <div class="custom-spin">
                                    <button @onclick='() => { if(customBreakMin > 1) customBreakMin -= 1; breakMinutes = customBreakMin; }'>−</button>
                                    <span>@customBreakMin dk</span>
                                    <button @onclick='() => { if(customBreakMin < 30) customBreakMin += 1; breakMinutes = customBreakMin; }'>+</button>
                                </div>
                            </div>
                        </div>
                    }
                    else if (selectedMode > 0)
                    {
                        <!-- BREAK DURATION CHIPS (only for countdown modes) -->
                        <div class="break-chip-row mb-3">
                            <span class="break-chip-label"><i class="bi bi-cup-hot"></i> Mola:</span>
                            @foreach (var bm in new[] { 5, 10, 15 })
                            {
                                <button class="break-chip @(breakMinutes == bm ? "active" : "")" @onclick='() => breakMinutes = bm'>
                                    @bm dk
                                </button>
                            }
                        </div>
                    }
                }

                @if (GlobalTimer.IsBreak)
                {
                    <div class="break-mode-banner">
                        <i class="bi bi-cup-hot-fill"></i> Mola — @GlobalTimer.RemainingTime.ToString(@"mm\:ss")
                    </div>
                }

                <div class="timer-circle-wrapper">
                    <svg class="timer-svg" viewBox="0 0 200 200">
                        <circle cx="100" cy="100" r="90" class="timer-bg-ring" />

                        <circle cx="100" cy="100" r="90" class="timer-progress-ring neon-effect"
                                style="stroke: @workspace.Color;
                                           stroke-dasharray: 565;
                                           stroke-dashoffset: @timerDashOffset;
                                           color: @workspace.Color" />
                    </svg>
                    <div class="timer-text">
                        @DisplayTime.ToString(@"hh\:mm\:ss")
                    </div>
                    @if (GlobalTimer.IsCountdown)
                    {
                        <div class="timer-mode-badge" style="color: @(GlobalTimer.IsBreak ? "#22c55e" : workspace?.Color)">
                            @(GlobalTimer.IsBreak ? "MOLA" : (selectedMode == 25 ? "Klasik" : selectedMode == 50 ? "Derin Odak" : "Özel"))
                        </div>
                    }
                </div>

                @if (isTimerRunning && !GlobalTimer.IsBreak)
                {
                    <button class="btn-focus-mode mt-2" @onclick="EnterFocusMode" title="Odak Modu">
                        <i class="bi bi-fullscreen"></i> Odak Modu
                    </button>
                }

                @if (showBreakAlert)
                {
                    <div class="break-alert-card mt-3">
                        <div class="break-alert-icon"><i class="bi bi-alarm-fill"></i></div>
                        <p class="break-alert-msg">Mola bitti!<br/><small>Yeni bir seansa hazır mısın?</small></p>
                        <div class="break-alert-actions">
                            <button class="break-alert-btn primary" @onclick="StartTimer">
                                <i class="bi bi-play-fill"></i> Başla
                            </button>
                            <button class="break-alert-btn secondary" @onclick="DismissBreakAlert">Kapat</button>
                        </div>
                    </div>
                }

                <div class="timer-controls mt-4 d-flex gap-3">
                    @if (elapsedTime.TotalSeconds == 0 && !GlobalTimer.IsPaused)
                    {
                        <button class="btn-timer-main start" style="background-color: @workspace.Color" @onclick="StartTimer">
                            <i class="bi bi-play-fill"></i> BAŞLA
                        </button>
                    }
                    else if (!isTimerRunning)
                    {
                        <button class="btn-timer-main start" style="background-color: @workspace.Color" @onclick="StartTimer">
                            <i class="bi bi-play-fill"></i> DEVAM ET
                        </button>
                        <button class="btn-timer-secondary stop" @onclick="StopTimer">BİTİR</button>
                    }
                    else
                    {
                        <button class="btn-timer-main pause" @onclick="PauseTimer">DURAKLAT</button>
                        <button class="btn-timer-secondary stop" @onclick="StopTimer">BİTİR</button>
                    }
                </div>
            </div>

            <div class="ws-card notes-panel">
                <div class="panel-header">
                    <h5>Hızlı Notlar</h5>
                    <div class="d-flex gap-2 align-items-center">
                        @if (showSaveMessage)
                        {
                            <span class="text-success small fw-bold fade-in me-2"><i class="bi bi-check-lg"></i> Kaydedildi</span>
                        }
                        <button class="btn-note-action" @onclick="SaveNotes" title="Kaydet"><i class="bi bi-save"></i></button>
                        <button class="btn-note-action text-danger" @onclick="ClearNotes" title="Temizle"><i class="bi bi-trash"></i></button>
                    </div>
                </div>
                <textarea class="ws-note-input" @bind="noteContent" placeholder="Notlarını al..."></textarea>
            </div>
        </div>
    }
    else
    {
        <div class="d-flex flex-column justify-content-center align-items-center h-100 text-center">
            <div class="text-muted mb-3" style="font-size: 3rem;"><i class="bi bi-exclamation-circle"></i></div>
            <h3 class="text-white">Ders Bulunamadı</h3>
            <a href="lessons" class="btn btn-outline-light mt-3">Geri Dön</a>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private WorkspaceDetailDto? workspace;
    private bool isLoading = true;



    // Ekranda gösterilecek süre
    private TimeSpan DisplayTime =>
        (isTimerRunning || GlobalTimer.IsPaused) ? GlobalTimer.RemainingTime : PreviewTime;

    // Mod seçiliyken başlamadan önce gösterilen önizleme süresi
    private TimeSpan PreviewTime =>
        isCustomMode ? TimeSpan.FromMinutes(customWorkMin) :
        selectedMode == 0 ? TimeSpan.Zero : TimeSpan.FromMinutes(selectedMode);

    // Timer state (synced from GlobalTimerService)
    private bool isTimerRunning => GlobalTimer.IsRunning;
    private TimeSpan elapsedTime => GlobalTimer.IsRunning || GlobalTimer.IsPaused ? GlobalTimer.ElapsedTime : TimeSpan.Zero;
    private Guid? activeTaskId = null;

    // Animasyon
    private double timerDashOffset = 0;
    private const double CIRCUMFERENCE = 565;

    // Task
    private bool showAddTask = false;
    private CreateTaskDto newTask = new();

    // Notlar
    private string noteContent = "";

    // Pomodoro: preset & break
    private int selectedMode     = 0;    // çalışma dk (0 = serbest)
    private bool isCustomMode    = false; // özel mod aktif mi (panel açık kalır)
    private int breakMinutes     = 5;    // mola dk
    private int customWorkMin    = 25;   // özel mod: çalışma dk
    private int customBreakMin   = 5;    // özel mod: mola dk
    private bool showBreakAlert  = false; // mola bitti uyarısı

    protected override async Task OnInitializedAsync()
    {
        GlobalTimer.OnTick          += OnTimerTick;
        GlobalTimer.OnTimerFinished += OnTimerFinished;
        GlobalTimer.OnBreakFinished += OnBreakFinished;
        await LoadData();

        if (GlobalTimer.IsRunning && GlobalTimer.ActiveLessonId == Id)
        {
            activeTaskId = GlobalTimer.ActiveTaskId;
            CalculateProgress();
        }
    }

    private async Task LoadData()
    {
        workspace = await LessonService.GetWorkspaceDetailAsync(Id);

        // Notları yükle
        if (workspace != null)
        {
            noteContent = workspace.Note ?? "";
        }

        isLoading = false;
    }

    private async Task SelectTask(Guid taskId)
    {
        if (activeTaskId == taskId && isTimerRunning)
            PauseTimer();
        else
        {
            activeTaskId = taskId;
            if (!isTimerRunning) await StartTimer();
        }
    }

    private async Task StartTimer()
    {
        var color = workspace?.Color ?? "#3b82f6";

        int workMin  = isCustomMode ? customWorkMin  : selectedMode;
        int breakMin = isCustomMode ? customBreakMin : breakMinutes;

        TimeSpan? countdown = workMin > 0 ? TimeSpan.FromMinutes(workMin)    : null;
        TimeSpan? breakSpan = workMin > 0 && breakMin > 0
                                  ? TimeSpan.FromMinutes(breakMin) : null;

        await GlobalTimer.StartAsync(Id, activeTaskId, color,
            countdown: countdown, breakDuration: breakSpan);
    }

    private void PauseTimer()
    {
        GlobalTimer.Pause();
    }

    private async Task StopTimer()
    {
        await GlobalTimer.StopAsync();
        activeTaskId    = null;
        timerDashOffset = 0;
        showBreakAlert  = false;
    }

    /// Preset seçimi: Klasik 25/5, Derin Odak 50/10, Serbest 0/0, Özel -1
    private void SelectPreset(int workMin, int breakMin)
    {
        if (workMin == -1)
        {
            // Özel mod: paneli aç, selectedMode'u sıfırla
            isCustomMode = true;
            selectedMode = 0;
            breakMinutes = customBreakMin;
        }
        else
        {
            isCustomMode = false;
            selectedMode = workMin;
            breakMinutes = breakMin;
        }
    }

    private void SelectMode(int minutes)
    {
        selectedMode = minutes;
    }

    private void OnTimerTick()
    {
        if (GlobalTimer.ActiveLessonId == Id)
        {
            CalculateProgress();
        }
        InvokeAsync(StateHasChanged);
    }

    private async void OnTimerFinished()
    {
        GlobalTimer.SetFocusMode(false);

        // Eğer mola süresi ayarlandıysa otomatik molayı başlat
        if (GlobalTimer.BreakDuration > TimeSpan.Zero && GlobalTimer.ActiveLessonId == Id)
        {
            await InvokeAsync(async () =>
            {
                await GlobalTimer.StartBreakAsync();
                StateHasChanged();
            });
        }
        else
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnBreakFinished()
    {
        showBreakAlert = true;
        selectedMode   = 0;
        InvokeAsync(StateHasChanged);
    }

    private void DismissBreakAlert()
    {
        showBreakAlert = false;
        StateHasChanged();
    }

    private void CalculateProgress()
    {
        if (GlobalTimer.IsCountdown && GlobalTimer.InitialDuration.TotalSeconds > 0)
        {
            // Geri sayım: kalan süreyi toplam süreye oranı olarak hesapla
            double fraction = GlobalTimer.RemainingTime.TotalSeconds / GlobalTimer.InitialDuration.TotalSeconds;
            timerDashOffset = CIRCUMFERENCE * (1 - fraction);
        }
        else
        {
            // İleri sayım: saat bazında dönüş
            double currentSecondInHour = GlobalTimer.ElapsedTime.TotalSeconds % 3600;
            double fraction = currentSecondInHour / 3600.0;
            timerDashOffset = CIRCUMFERENCE * (1 - fraction);
        }
    }

    private void EnterFocusMode()
    {
        GlobalTimer.SetFocusMode(true);
    }

    private async Task AddNewTask()
    {
        if (string.IsNullOrWhiteSpace(newTask.Title)) return;

        newTask.LessonId = Id;
        newTask.Status = StudyTime.Domain.Enums.TaskStatus.Pending;

        var success = await LessonService.CreateTaskAsync(newTask);
        if (success)
        {
            newTask = new CreateTaskDto(); // Formu sıfırla
            showAddTask = false;
            await LoadData();
        }
    }

    // Feedback
    private bool showSaveMessage = false;

    private async Task SaveNotes()
    {
        if (workspace == null) return;
        
        var success = await LessonService.UpdateNotesAsync(Id, noteContent);
        if (success)
        {
            showSaveMessage = true;
            StateHasChanged();
            await Task.Delay(2000); // 2 saniye göster
            showSaveMessage = false;
            StateHasChanged();
        }
    }

    private void ClearNotes()
    {
        noteContent = "";
    }

    private async Task ToggleTaskStatus(TaskListItemDto task)
    {
        task.IsCompleted = !task.IsCompleted;
        StateHasChanged(); // Optimistik güncelleme

        try 
        {
             var newStatus = task.IsCompleted ? StudyTime.Domain.Enums.TaskStatus.Completed : StudyTime.Domain.Enums.TaskStatus.Pending;
             await TaskApiService.UpdateTaskStatusAsync(task.Id, newStatus);

             // OTOMATİK SİLME (Eğer tamamlandıysa)
             if (task.IsCompleted && workspace != null)
             {
                 await Task.Delay(1000); // 1 saniye beklet
                 workspace.Tasks.Remove(task); // Listeden kaldır
                 StateHasChanged();
             }
        }
        catch
        {
             task.IsCompleted = !task.IsCompleted; // Geri al
             StateHasChanged();
        }
    }

    public void Dispose()
    {
        GlobalTimer.OnTick -= OnTimerTick;
        GlobalTimer.OnTimerFinished -= OnTimerFinished;
    }
}

<style>
    /* Date Input Fix */
    input[type="datetime-local"] {
        padding-right: 10px !important; /* İkon için yer aç */
        font-size: 0.9rem;
    }
    
    /* Webkit (Chrome/Edge) specific fix for calendar icon spacing */
    input[type="datetime-local"]::-webkit-calendar-picker-indicator {
        margin-left: 5px;
        opacity: 0.6;
        cursor: pointer;
    }

    /* Custom Scrollbar for Task List */
    .task-list-scroll::-webkit-scrollbar {
        width: 6px;
    }
    .task-list-scroll::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.05); 
        border-radius: 4px;
    }
    .task-list-scroll::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.2); 
        border-radius: 4px;
    }
    .task-list-scroll::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.3); 
    }

    /* ── Preset Buttons ────────────────────────────────── */
    .timer-preset-row {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .btn-preset {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        padding: 8px 14px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.03);
        color: rgba(255,255,255,0.5);
        font-size: 0.78rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        min-width: 64px;
    }

    .btn-preset i { font-size: 1rem; }

    .btn-preset:hover {
        background: rgba(255,255,255,0.08);
        color: #fff;
        border-color: rgba(255,255,255,0.18);
    }

    .btn-preset.active {
        background: rgba(255,255,255,0.12);
        color: #fff;
        border-color: rgba(255,255,255,0.25);
        box-shadow: 0 0 10px rgba(255,255,255,0.06);
    }

    .preset-sub {
        font-size: 0.65rem;
        opacity: 0.55;
        background: rgba(255,255,255,0.08);
        border-radius: 6px;
        padding: 0 5px;
    }

    /* ── Break Chips ────────────────────────────────────── */
    .break-chip-row {
        display: flex;
        align-items: center;
        gap: 6px;
        justify-content: center;
    }

    .break-chip-label {
        font-size: 0.75rem;
        color: rgba(255,255,255,0.45);
    }

    .break-chip {
        padding: 3px 10px;
        border-radius: 999px;
        border: 1px solid rgba(34,197,94,0.25);
        background: rgba(34,197,94,0.06);
        color: rgba(255,255,255,0.5);
        font-size: 0.75rem;
        cursor: pointer;
        transition: all 0.2s;
    }

    .break-chip:hover, .break-chip.active {
        background: rgba(34,197,94,0.18);
        border-color: rgba(34,197,94,0.5);
        color: #22c55e;
    }

    /* ── Custom Mode Spinner ────────────────────────────── */
    .custom-mode-row {
        display: flex;
        align-items: center;
        gap: 12px;
        justify-content: center;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 12px;
        padding: 10px 16px;
    }

    .custom-field { display: flex; flex-direction: column; align-items: center; gap: 4px; }

    .custom-label {
        font-size: 0.68rem;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .custom-spin {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .custom-spin button {
        width: 26px; height: 26px;
        border-radius: 50%;
        border: 1px solid rgba(255,255,255,0.15);
        background: rgba(255,255,255,0.06);
        color: #fff;
