@page "/workspace/{Id:guid}"
@using StudyTime.Application.DTOs.Lessons
@using StudyTime.Application.DTOs.Tasks
@using StudyTime.DesktopClient.Services
@using StudyTime.Domain.Enums

@inject LessonApiService LessonService
@inject StudySessionApiService SessionApiService
@inject TaskApiService TaskApiService

<div class="workspace-container fade-in">
    @if (isLoading)
    {
        <div class="d-flex justify-content-center align-items-center h-100">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else if (workspace != null)
    {
        <div class="ws-header mb-4">
            <a href="lessons" class="btn-back"><i class="bi bi-arrow-left"></i> Geri</a>
            <h2 class="m-0 fw-bold" style="color: @workspace.Color">@workspace.Name</h2>
            <span class="badge-soft text-muted">Çalışma Odası</span>
        </div>

        <div class="ws-grid">

            <div class="ws-card task-panel">
                <div class="panel-header">
                    <h5>Görevler</h5>
                    <button class="btn-icon-xs" @onclick="() => showAddTask = !showAddTask">
                        <i class="bi @(showAddTask ? "bi-x-lg" : "bi-plus-lg")"></i>
                    </button>
                </div>

                @if (showAddTask)
                {
                    <div class="task-creation-form mb-3 fade-in p-3" style="background: rgba(255,255,255,0.05); border-radius: 12px; border: 1px solid rgba(255,255,255,0.1);">
                        <div class="mb-2">
                            <label class="text-white small mb-1 opacity-75">Görev Adı</label>
                            <input type="text" class="form-control custom-input" placeholder="Örn: Matematik çalış..." @bind="newTask.Title" />
                        </div>
                        
                        <div class="row g-2 mb-2">
                             <div class="col-6">
                                <label class="text-white small mb-1 opacity-75">Başlangıç</label>
                                <input type="datetime-local" class="form-control custom-input" @bind="newTask.StartDate" />
                             </div>
                             <div class="col-6">
                                <label class="text-white small mb-1 opacity-75">Bitiş</label>
                                <input type="datetime-local" class="form-control custom-input" @bind="newTask.EndDate" />
                             </div>
                        </div>

                        <div class="mb-2">
                             <label class="text-white small mb-1 opacity-75">Tahmini Süre (Dk)</label>
                             <input type="number" class="form-control custom-input" placeholder="45" @bind="newTask.PlannedDurationMinutes" />
                        </div>

                        <div class="mb-3">
                             <label class="text-white small mb-1 opacity-75">Not</label>
                             <textarea class="form-control custom-input" rows="2" placeholder="Detaylar..." @bind="newTask.Note"></textarea>
                        </div>

                        <button class="btn-add-task w-100 py-2 fw-bold" 
                                style="background: linear-gradient(135deg, @workspace.Color, #3b82f6); border:none; border-radius:8px; color:white;"
                                @onclick="AddNewTask">
                            <i class="bi bi-plus-circle-fill me-2"></i> GÖREVİ OLUŞTUR
                        </button>
                    </div>
                }

                <div class="task-list-scroll">
                    @if (workspace.Tasks.Any())
                    {
                        var visibleTasks = workspace.Tasks.Where(t => !t.IsCompleted).ToList();
                        
                        @if (visibleTasks.Any()) 
                        {
                            @foreach (var task in visibleTasks)
                            {
                                <div class="ws-task-item @(activeTaskId == task.Id ? "active-task" : "")"
                                     style="--accent-color: @workspace.Color">
    
                                    <div class="d-flex align-items-center gap-2" style="flex: 1; overflow: hidden;">
                                        <input type="checkbox" class="form-check-input custom-check" 
                                               checked="@task.IsCompleted" 
                                               @onchange="@(async (e) => await ToggleTaskStatus(task))"
                                               style="cursor: pointer; flex-shrink: 0;" />
                                        
                                        <div class="d-flex align-items-baseline gap-2 text-truncate">
                                            <span class="@(task.IsCompleted ? "text-decoration-line-through text-muted" : "text-white") fw-medium">
                                                @task.Title
                                            </span>
                                            @if (!string.IsNullOrEmpty(task.Note))
                                            {
                                                <span class="text-white opacity-50 small text-truncate" style="max-width: 150px;" title="@task.Note">
                                                    - @task.Note
                                                </span>
                                            }
                                        </div>
                                    </div>
    
                                    <button class="btn-play-task" @onclick="() => SelectTask(task.Id)">
                                        @if (activeTaskId == task.Id && isTimerRunning)
                                        {
                                            <i class="bi bi-pause-fill"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-play-fill"></i>
                                        }
                                    </button>
                                </div>
                            }
                        }
                        else 
                        {
                             <div class="text-center text-muted py-4 small">Tüm görevler tamamlandı! 🎉</div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-4 small">Henüz görev yok.</div>
                    }
                </div>
            </div>

            <div class="ws-card timer-panel d-flex flex-column align-items-center justify-content-center">
                <div class="current-task-display mb-4">
                    @if (activeTaskId != null)
                    {
                        var t = workspace.Tasks.FirstOrDefault(x => x.Id == activeTaskId);
                        <span class="text-muted small">Şu an çalışılıyor:</span>
                        <div class="fw-bold text-white">@t?.Title</div>
                    }
                    else
                    {
                        <span class="text-muted small">Serbest Çalışma Modu</span>
                    }
                </div>

                <div class="timer-circle-wrapper">
                    <svg class="timer-svg" viewBox="0 0 200 200">
                        <circle cx="100" cy="100" r="90" class="timer-bg-ring" />

                        <circle cx="100" cy="100" r="90" class="timer-progress-ring neon-effect"
                                style="stroke: @workspace.Color;
                                           stroke-dasharray: 565;
                                           stroke-dashoffset: @timerDashOffset;
                                           color: @workspace.Color" />
                    </svg>
                    <div class="timer-text">
                        @elapsedTime.ToString(@"hh\:mm\:ss")
                    </div>
                </div>

                <div class="timer-controls mt-4 d-flex gap-3">
                    @if (elapsedTime.TotalSeconds == 0)
                    {
                        <button class="btn-timer-main start" style="background-color: @workspace.Color" @onclick="StartTimer">
                            <i class="bi bi-play-fill"></i> BAŞLA
                        </button>
                    }
                    else if (!isTimerRunning)
                    {
                        <button class="btn-timer-main start" style="background-color: @workspace.Color" @onclick="StartTimer">
                            <i class="bi bi-play-fill"></i> DEVAM ET
                        </button>
                        <button class="btn-timer-secondary stop" @onclick="StopTimer">BİTİR</button>
                    }
                    else
                    {
                        <button class="btn-timer-main pause" @onclick="PauseTimer">DURAKLAT</button>
                        <button class="btn-timer-secondary stop" @onclick="StopTimer">BİTİR</button>
                    }
                </div>
            </div>

            <div class="ws-card notes-panel">
                <div class="panel-header">
                    <h5>Hızlı Notlar</h5>
                    <div class="d-flex gap-2 align-items-center">
                        @if (showSaveMessage)
                        {
                            <span class="text-success small fw-bold fade-in me-2"><i class="bi bi-check-lg"></i> Kaydedildi</span>
                        }
                        <button class="btn-note-action" @onclick="SaveNotes" title="Kaydet"><i class="bi bi-save"></i></button>
                        <button class="btn-note-action text-danger" @onclick="ClearNotes" title="Temizle"><i class="bi bi-trash"></i></button>
                    </div>
                </div>
                <textarea class="ws-note-input" @bind="noteContent" placeholder="Notlarını al..."></textarea>
            </div>
        </div>
    }
    else
    {
        <div class="d-flex flex-column justify-content-center align-items-center h-100 text-center">
            <div class="text-muted mb-3" style="font-size: 3rem;"><i class="bi bi-exclamation-circle"></i></div>
            <h3 class="text-white">Ders Bulunamadı</h3>
            <a href="lessons" class="btn btn-outline-light mt-3">Geri Dön</a>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private WorkspaceDetailDto? workspace;
    private bool isLoading = true;

    // Timer & Session
    private bool isTimerRunning = false;
    private TimeSpan elapsedTime = TimeSpan.Zero;
    private System.Timers.Timer? _timer;
    private Guid? activeTaskId = null;

    // Veritabanındaki oturumu takip etmek için
    private Guid? currentSessionId = null;

    // Animasyon
    private double timerDashOffset = 0;
    private const double CIRCUMFERENCE = 565;

    // Task
    private bool showAddTask = false;
    private CreateTaskDto newTask = new();

    // Notlar
    private string noteContent = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        workspace = await LessonService.GetWorkspaceDetailAsync(Id);

        // Notları yükle
        if (workspace != null)
        {
            noteContent = workspace.Note ?? "";
        }

        isLoading = false;
    }

    private async Task SelectTask(Guid taskId)
    {
        if (activeTaskId == taskId && isTimerRunning)
            await PauseTimer();
        else
        {
            activeTaskId = taskId;
            if (!isTimerRunning) await StartTimer();
        }
    }

    private async Task StartTimer()
    {
        if (_timer == null)
        {
            _timer = new System.Timers.Timer(1000);
            _timer.Elapsed += (s, e) =>
            {
                elapsedTime = elapsedTime.Add(TimeSpan.FromSeconds(1));
                CalculateProgress();
                InvokeAsync(StateHasChanged);
            };
        }
        _timer.Start();
        isTimerRunning = true;

        // API İŞLEMLERİ
        if (currentSessionId == null || currentSessionId == Guid.Empty)
        {
            // Hiç oturum yoksa SIFIRDAN BAŞLAT
            var sessionId = await SessionApiService.StartSessionAsync(Id, activeTaskId);
            if (sessionId != Guid.Empty)
            {
                currentSessionId = sessionId;
            }
        }
        else
        {
            // Oturum varsa (yani duraklatılmışsa) DEVAM ET (RESUME)
            await SessionApiService.ResumeSessionAsync(currentSessionId.Value);
        }
    }

    private async Task PauseTimer()
    {
        _timer?.Stop();
        isTimerRunning = false;

        // API İŞLEMLERİ: Duraklatma İsteği Gönder
        if (currentSessionId != null && currentSessionId != Guid.Empty)
        {
            await SessionApiService.PauseSessionAsync(currentSessionId.Value);
        }
    }

    private async Task StopTimer()
    {
        _timer?.Stop();
        isTimerRunning = false;

        // API'ye Session Bitirme İsteği Gönder
        if (currentSessionId != null && currentSessionId != Guid.Empty)
        {
            await SessionApiService.StopSessionAsync(currentSessionId.Value);
            currentSessionId = null; // Sıfırla ki yeni bir tane başlatılabilsin
        }

        // Arayüzü Sıfırla
        elapsedTime = TimeSpan.Zero;
        activeTaskId = null;
        timerDashOffset = 0;
    }

    private void CalculateProgress()
    {
        double currentSecondInHour = elapsedTime.TotalSeconds % 3600;
        double fraction = currentSecondInHour / 3600.0;
        timerDashOffset = CIRCUMFERENCE * (1 - fraction);
    }

    private async Task AddNewTask()
    {
        if (string.IsNullOrWhiteSpace(newTask.Title)) return;

        newTask.LessonId = Id;
        newTask.Status = StudyTime.Domain.Enums.TaskStatus.Pending;

        var success = await LessonService.CreateTaskAsync(newTask);
        if (success)
        {
            newTask = new CreateTaskDto(); // Formu sıfırla
            showAddTask = false;
            await LoadData();
        }
    }

    // Feedback
    private bool showSaveMessage = false;

    private async Task SaveNotes()
    {
        if (workspace == null) return;
        
        var success = await LessonService.UpdateNotesAsync(Id, noteContent);
        if (success)
        {
            showSaveMessage = true;
            StateHasChanged();
            await Task.Delay(2000); // 2 saniye göster
            showSaveMessage = false;
            StateHasChanged();
        }
    }

    private void ClearNotes()
    {
        noteContent = "";
    }

    private async Task ToggleTaskStatus(TaskListItemDto task)
    {
        task.IsCompleted = !task.IsCompleted;
        StateHasChanged(); // Optimistik güncelleme

        try 
        {
             var newStatus = task.IsCompleted ? StudyTime.Domain.Enums.TaskStatus.Completed : StudyTime.Domain.Enums.TaskStatus.Pending;
             await TaskApiService.UpdateTaskStatusAsync(task.Id, newStatus);

             // OTOMATİK SİLME (Eğer tamamlandıysa)
             if (task.IsCompleted && workspace != null)
             {
                 await Task.Delay(1000); // 1 saniye beklet
                 workspace.Tasks.Remove(task); // Listeden kaldır
                 StateHasChanged();
             }
        }
        catch
        {
             task.IsCompleted = !task.IsCompleted; // Geri al
             StateHasChanged();
        }
    }

    public void Dispose() { _timer?.Dispose(); }
}

<style>
    /* Date Input Fix */
    input[type="datetime-local"] {
        padding-right: 10px !important; /* İkon için yer aç */
        font-size: 0.9rem;
    }
    
    /* Webkit (Chrome/Edge) specific fix for calendar icon spacing */
    input[type="datetime-local"]::-webkit-calendar-picker-indicator {
        margin-left: 5px;
        opacity: 0.6;
        cursor: pointer;
    }

    /* Custom Scrollbar for Task List */
    .task-list-scroll::-webkit-scrollbar {
        width: 6px;
    }
    .task-list-scroll::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.05); 
        border-radius: 4px;
    }
    .task-list-scroll::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.2); 
        border-radius: 4px;
    }
    .task-list-scroll::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.3); 
    }
</style>
