@page "/tasks"
@using StudyTime.Application.DTOs.Tasks
@using StudyTime.Application.DTOs.Lessons
@using StudyTime.DesktopClient.Services
@using StudyTime.DesktopClient.Offline
@using System.Globalization
@inject SyncedTaskApiService TaskService
@inject SyncedLessonApiService LessonService

<div class="calendar-container fade-in">
    <!-- Header -->
    <div class="calendar-header mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h1 class="text-2xl fw-bold text-white m-0">Görev Takvimi</h1>
            <p class="text-white opacity-75 small m-0">Planla ve organize et</p>
        </div>
        <div class="d-flex align-items-center gap-3">
             <button class="btn-icon-sm" @onclick="PreviousMonth"><i class="bi bi-chevron-left"></i></button>
             <span class="fs-4 fw-bold text-white" style="min-width: 200px; text-align: center;">@CurrentMonthName @CurrentYear</span>
             <button class="btn-icon-sm" @onclick="NextMonth"><i class="bi bi-chevron-right"></i></button>
             <button class="btn-primary ms-3" @onclick="GoToToday">Bugün</button>
        </div>
    </div>

    <!-- Calendar Grid -->
    <div class="calendar-grid">
        <!-- Day Names -->
        @foreach (var day in Enum.GetValues(typeof(DayOfWeek)).Cast<DayOfWeek>().OrderBy(d => (int)d == 0 ? 7 : (int)d))
        {
            <div class="calendar-day-header">
                @CurrentCulture.DateTimeFormat.GetAbbreviatedDayName(day)
            </div>
        }

        <!-- Days -->
        @if (isLoading)
        {
             @for (int i = 0; i < 35; i++)
             {
                 <div class="calendar-cell skeleton-cell"></div>
             }
        }
        else
        {
            @foreach (var day in CalendarDays)
            {
                <div class="calendar-cell @(day.IsCurrentMonth ? "" : "opacity-50") @(IsToday(day.Date) ? "today" : "")"
                     style="background-color: @GetHeatmapColor(day.Tasks.Count);"
                     @onclick="() => SelectDay(day)">
                    
                    <div class="cell-header d-flex justify-content-between">
                        <span class="day-number">@day.Date.Day</span>
                        @if (day.Tasks.Any())
                        {
                            <span class="badge bg-dark rounded-pill" style="font-size: 0.6rem;">@day.Tasks.Count</span>
                        }
                    </div>

                    <div class="cell-content">
                        @foreach (var task in day.Tasks.Take(3)) 
                        {
                             var dotColor = task.Lesson?.Color ?? "#fff";
                             if (task.Status == StudyTime.Domain.Enums.TaskStatus.Completed)
                             {
                                 <div class="task-dot-completed" title="@task.Title - Tamamlandı">
                                     <svg viewBox="0 0 10 10" width="10" height="10" stroke="@dotColor" stroke-width="2.5" opacity="0.6" stroke-linecap="round">
                                         <line x1="2" y1="2" x2="8" y2="8" />
                                         <line x1="8" y1="2" x2="2" y2="8" />
                                     </svg>
                                 </div>
                             }
                             else
                             {
                                 <div class="task-dot" style="background-color: @dotColor;" title="@task.Title"></div>
                             }
                        }
                        @if(day.Tasks.Count > 3)
                        {
                            <div class="task-dot-more">+@(day.Tasks.Count - 3)</div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Task Detail Modal -->
@if (selectedDay != null)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content custom-modal">
                <div class="modal-header border-0">
                    <div>
                        <h5 class="modal-title fw-bold text-white">@selectedDay.Date.ToString("dd MMMM dddd", CurrentCulture)</h5>
                         <span class="text-white opacity-50 small">@selectedDay.Tasks.Count Görev</span>
                    </div>
                    <button type="button" class="modal-close-adaptive" @onclick="CloseModal" aria-label="Kapat">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div class="modal-body" style="max-height: 500px; overflow-y: auto;">
                    @if (selectedDay.Tasks.Any())
                    {
                        <div class="d-flex flex-column gap-2">
                            @foreach (var task in selectedDay.Tasks)
                            {
                                <div class="st-card p-3 d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" checked="@IsTaskCompleted(task)"
                                                   disabled="@IsTaskCompleted(task)"
                                                   @onchange="(e) => ToggleTaskStatus(task, e.Value)">
                                        </div>
                                        <div>
                                            <div class="fw-medium text-white @(IsTaskCompleted(task) ? "text-decoration-line-through opacity-50" : "")">
                                                @task.Title
                                            </div>
                                            <div class="small opacity-50" style="color: @(task.Lesson?.Color ?? "#fff");">
                                                <i class="bi bi-circle-fill me-1" style="font-size: 6px;"></i>
                                                @(task.Lesson?.Name ?? "Genel")
                                            </div>
                                            @if (task.EndDate.HasValue)
                                            {
                                                <div class="small mt-1 task-due-date">
                                                    <i class="bi bi-calendar-check me-1"></i>
                                                    Bitiş: @task.EndDate.Value.ToString("dd MMM HH:mm", CurrentCulture)
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <div class="d-flex gap-2 align-items-center">
                                        @if(task.PlannedDuration.HasValue)
                                        {
                                            <span class="badge bg-dark text-white opacity-75 h-100 d-flex align-items-center">@GetFormattedDuration(task.PlannedDuration.Value)</span>
                                        }
                                        <button class="btn btn-sm" style="border: 1px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.05); border-radius: 6px; color: white;" 
                                                @onclick="() => selectedDetailTask = task">
                                            <i class="bi bi-info-circle me-1"></i> Detay
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-white opacity-50">
                            <i class="bi bi-calendar-x fs-1 mb-2"></i>
                            <p>Bugün için planlanmış görev yok.</p>
                        </div>
                    }
                </div>
                <div class="modal-footer border-0">
                <div class="modal-footer border-0">
                    <!-- Buton kaldırıldı -->
                </div>
                </div>
            </div>
        </div>
    </div>
    
}

<!-- Alt Görev Detay Modalı (Yeni Ekleme) -->
@if (selectedDetailTask != null)
{
    <div class="modal-backdrop fade show" style="z-index: 1060;"></div>
    <div class="modal fade show d-block" tabindex="-1" style="z-index: 1065;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="background: linear-gradient(145deg, #2b2b2b, #1f1f1f); border-radius: 12px;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold text-white d-flex align-items-center">
                        <i class="bi bi-list-task me-2" style="color: @(selectedDetailTask.Lesson?.Color ?? "#fff")"></i> 
                        <span style="font-size: 1.1rem; line-height: 1.2;">@selectedDetailTask.Title</span>
                    </h5>
                    <button type="button" class="modal-close-adaptive" @onclick="() => selectedDetailTask = null" aria-label="Kapat">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="p-3 mb-3" style="background: rgba(255,255,255,0.05); border-radius: 8px;">
                        <h6 class="text-white opacity-75 small text-uppercase mb-2"><i class="bi bi-card-text me-1"></i>Açıklama</h6>
                        <p class="text-white m-0" style="font-size: 0.95rem; word-wrap: break-word; word-break: break-all; white-space: pre-wrap; max-height: 200px; overflow-y: auto;">
                            @(string.IsNullOrWhiteSpace(selectedDetailTask.Note) ? "Bu görev için açıklama veya not bulunmuyor." : selectedDetailTask.Note)
                        </p>
                    </div>

                    <div class="row g-2">
                         <div class="col-6">
                            <div class="p-2 h-100" style="background: rgba(255,255,255,0.03); border-radius: 8px;">
                                <div class="text-white opacity-50 small mb-1"><i class="bi bi-clock-history"></i> Tahmini Süre</div>
                                <div class="fw-bold text-white fs-6">
                                    @(selectedDetailTask.PlannedDuration.HasValue ? GetFormattedDuration(selectedDetailTask.PlannedDuration.Value) : "-")
                                </div>
                            </div>
                         </div>
                         <div class="col-6">
                            <div class="p-2 h-100" style="background: rgba(255,255,255,0.03); border-radius: 8px;">
                                <div class="text-white opacity-50 small mb-1"><i class="bi bi-tag"></i> Ders</div>
                                <div class="fw-bold fs-6" style="color: @(selectedDetailTask.Lesson?.Color ?? "#fff")">
                                    @(selectedDetailTask.Lesson?.Name ?? "Genel")
                                </div>
                            </div>
                         </div>
                         <div class="col-12 mt-2">
                             <div class="d-flex justify-content-between p-2" style="background: rgba(255,255,255,0.03); border-radius: 8px;">
                                 <div>
                                     <div class="text-white opacity-50 small"><i class="bi bi-calendar-event"></i> Başlangıç</div>
                                     <div class="text-white small fw-medium mt-1">@(selectedDetailTask.StartDate?.ToString("dd MMM yyyy HH:mm", CurrentCulture) ?? "-")</div>
                                 </div>
                                 <div class="text-end">
                                     <div class="text-white opacity-50 small"><i class="bi bi-calendar-check"></i> Bitiş (Hedef)</div>
                                     <div class="text-white small fw-medium mt-1">@(selectedDetailTask.EndDate?.ToString("dd MMM yyyy HH:mm", CurrentCulture) ?? "-")</div>
                                 </div>
                             </div>
                         </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
<style>
    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 1px;
        background-color: var(--border-color);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-xl);
        overflow: hidden;
    }

    .calendar-day-header {
        background-color: var(--bg-card);
        color: var(--text-muted);
        text-align: center;
        padding: 10px;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
    }

    .calendar-cell {
        background-color: var(--bg-card); /* Default bg, overridden by heatmap */
        min-height: 120px;
        padding: 8px;
        cursor: pointer;
        transition: background-color 0.2s;
        position: relative;
    }

    .calendar-cell:hover {
        filter: brightness(1.2);
    }
    
    .calendar-cell.today {
        border: 2px solid var(--accent-blue);
    }

    .skeleton-cell {
        background-color: var(--bg-surface);
        animation: pulse 1.5s infinite;
    }
    
    @@keyframes pulse {
        0% { opacity: 0.6; }
        50% { opacity: 1; }
        100% { opacity: 0.6; }
    }

    .cell-header {
        margin-bottom: 6px;
    }

    .day-number {
        font-weight: 600;
        color: var(--text-main);
    }

    .cell-content {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
    }

    .task-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .task-dot-completed {
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
    
    .task-dot-more {
        font-size: 0.6rem;
        color: var(--text-muted);
    }

    .task-due-date {
        color: var(--text-dim);
    }

    /* Adaptive modal close button — works in dark & light mode */
    .modal-close-adaptive {
        background: none;
        border: none;
        font-size: 1.1rem;
        color: var(--text-main);
        opacity: 0.6;
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 6px;
        line-height: 1;
        transition: opacity 0.15s, background 0.15s;
    }
    .modal-close-adaptive:hover {
        opacity: 1;
        background: var(--bg-surface);
    }

    /* Mobile Responsive Adjustments */
    @@media (max-width: 768px) {
        .calendar-grid {
            border-radius: var(--radius-md);
        }

        .calendar-cell {
            min-height: 80px; /* Reduced height */
            padding: 4px;
        }

        .calendar-day-header {
            font-size: 0.7rem;
            padding: 6px;
        }

        .day-number {
            font-size: 0.8rem;
        }

        .cell-header {
            margin-bottom: 4px;
        }
        
        /* Hide task detail dots if too many or make them smaller */
        .task-dot {
            width: 6px;
            height: 6px;
        }

        .calendar-header {
            flex-direction: column;
            gap: 1rem;
            align-items: flex-start !important;
        }
        
        .calendar-header .d-flex {
            width: 100%;
            justify-content: space-between;
        }
    }
</style>

@code {
    [Inject] NavigationManager Nav { get; set; } = default!;
    
    private DateTime CurrentDate = DateTime.Today;
    private CultureInfo CurrentCulture = new CultureInfo("tr-TR");
    
    private List<CalendarDay> CalendarDays = new();
    private bool isLoading = true;
    private CalendarDay? selectedDay;
    private TaskDto? selectedDetailTask;

    private string CurrentMonthName => CurrentDate.ToString("MMMM", CurrentCulture);
    private int CurrentYear => CurrentDate.Year;

    protected override async Task OnInitializedAsync()
    {
        await LoadCalendar();
    }

    private async Task LoadCalendar()
    {
        isLoading = true;
        CalendarDays.Clear();
        
        // Calculate start/end dates for the grid
        var firstDayOfMonth = new DateTime(CurrentDate.Year, CurrentDate.Month, 1);
        var lastDayOfMonth = firstDayOfMonth.AddMonths(1).AddDays(-1);
        
        // Calculate headers (Monday -> Sunday)
        // Find the Monday before or on the first day of the month
        var startGridDate = firstDayOfMonth;
        while (startGridDate.DayOfWeek != DayOfWeek.Monday)
        {
            startGridDate = startGridDate.AddDays(-1);
        }

        var endGridDate = startGridDate.AddDays(34); // Show 5 weeks (35 days) logic or dynamic
        // Ensure we cover the whole month. Sometimes 35 days aren't enough (e.g. Month starts on Sat/Sun and has 31 days)
        // Let's adapt dynamically:
        while (endGridDate < lastDayOfMonth || endGridDate.DayOfWeek != DayOfWeek.Sunday)
        {
             endGridDate = endGridDate.AddDays(1);
        }

        // Fetch Tasks (Range)
        var allTasks = await TaskService.GetTasksByDateRangeAsync(startGridDate, endGridDate);

        // Build Days
        for (var date = startGridDate; date <= endGridDate; date = date.AddDays(1))
        {
            var dayTasks = allTasks.Where(t => 
                (t.StartDate.HasValue && t.StartDate.Value.Date == date.Date) || 
                (t.EndDate.HasValue && t.EndDate.Value.Date == date.Date) ||
                (!t.StartDate.HasValue && !t.EndDate.HasValue && date.Date == DateTime.Today && t.Status == StudyTime.Domain.Enums.TaskStatus.Pending) // Show pending undated tasks on Today? Or imply usage of specific DueDate logic. Assuming EndDate is DueDate here.
            ).ToList();
            
            // Allow simplified logic: Task matches if EndDate is today, or StartDate is today.
            // Let's refine: Use "Planlanan Tarih" roughly mapping to Start or End.
            dayTasks = allTasks.Where(t => t.StartDate.HasValue && t.StartDate.Value.Date == date.Date).ToList();

            CalendarDays.Add(new CalendarDay
            {
                Date = date,
                IsCurrentMonth = date.Month == CurrentDate.Month,
                Tasks = dayTasks
            });
        }

        isLoading = false;
    }

    private async Task PreviousMonth()
    {
        CurrentDate = CurrentDate.AddMonths(-1);
        await LoadCalendar();
    }

    private async Task NextMonth()
    {
        CurrentDate = CurrentDate.AddMonths(1);
        await LoadCalendar();
    }
    
    private async Task GoToToday()
    {
        CurrentDate = DateTime.Today;
        await LoadCalendar();
    }

    private bool IsToday(DateTime date) => date.Date == DateTime.Today;

    private string GetHeatmapColor(int taskCount)
    {
        // Simple heatmap logic: Dark base with increasing opacity/lightness
        if (taskCount == 0) return "var(--bg-card)";
        
        // Use a base color with alpha
        var alpha = Math.Min(0.1 + (taskCount * 0.15), 0.6);
        return $"rgba(59, 130, 246, {alpha.ToString(CultureInfo.InvariantCulture)})"; // Blue-ish
    }

    private void SelectDay(CalendarDay day)
    {
        selectedDay = day;
    }

    private void CloseModal() => selectedDay = null;

    private async Task ToggleTaskStatus(TaskDto task, object? checkedValue)
    {
        bool isChecked = (bool)(checkedValue ?? false);
        var newStatus = isChecked ? StudyTime.Domain.Enums.TaskStatus.Completed : StudyTime.Domain.Enums.TaskStatus.Pending;

        if (!isChecked && task.Status == StudyTime.Domain.Enums.TaskStatus.Completed)
        {
            // Kullanıcı Görev Takviminden tamamlanmış görevi geri alamaz.
            return;
        }

        // Optimistic UI
        task.Status = newStatus;
        
        try 
        {
            await TaskService.UpdateTaskStatusAsync(task.Id, newStatus);
        }
        catch 
        {
            // Revert on error
             task.Status = isChecked ? StudyTime.Domain.Enums.TaskStatus.Pending : StudyTime.Domain.Enums.TaskStatus.Completed;
        }
    }
    
    private bool IsTaskCompleted(TaskDto task) => task.Status == StudyTime.Domain.Enums.TaskStatus.Completed;

    private string GetFormattedDuration(TimeSpan ts)
    {
        int totalMinutes = (int)ts.TotalMinutes;
        if (totalMinutes < 60) return $"{totalMinutes}dk";
        
        int hours = totalMinutes / 60;
        int minutes = totalMinutes % 60;
        return $"{hours}s {minutes}dk";
    }

    public class CalendarDay
    {
        public DateTime Date { get; set; }
        public bool IsCurrentMonth { get; set; }
        public List<TaskDto> Tasks { get; set; } = new();
    }
}
