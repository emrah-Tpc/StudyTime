@page "/statistics"
@using StudyTime.Application.DTOs.Statistics
@using StudyTime.DesktopClient.Services
@using StudyTime.DesktopClient.Offline
@using StudyTime.DesktopClient.Components.Charts
@using ApexCharts
@inject SyncedStatisticsApiService StatisticsService
@inject GlobalTimerService GlobalTimerService
@inject SyncStatusService SyncStatusService
@implements IDisposable

<div class="statistics-container fade-in">
    <div class="statistics-header-section mb-4">
        <div class="stat-header-text">
            <h1 class="stat-page-title">İstatistikler</h1>
            <p class="stat-page-subtitle">Çalışma verilerini analiz et</p>
        </div>

        <div class="stat-range-filters">
            @foreach (var r in new[] { "7days", "30days", "3months" })
            {
               <button class="stat-range-btn @(selectedRange == r ? "active" : "")" 
                       @onclick="() => SetRange(r)">
                   @(r == "7days" ? "7 Gün" : r == "30days" ? "30 Gün" : "3 Ay")
               </button>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center align-items-center" style="height: 60vh;">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else if (summary != null)
    {
        <div class="row g-3 mb-4">
            <div class="col-12 col-lg-8">
                <div class="st-card h-100" style="overflow: @(selectedRange == "7days" ? "visible" : "hidden");">
                    <div class="card-header py-2 d-flex justify-content-between align-items-start">
                        <div>
                            <span class="card-title text-white small text-uppercase fw-bold ls-1">Çalışma Geçmişi</span>
                            @if (selectedRange == "3months" && summary.StudyTrends.Any(t => t.Value > 0))
                            {
                                <div class="trend-daterange"><i class="bi bi-calendar3 me-1"></i>@MonthlyTrendData().Range</div>
                            }
                        </div>
                        @if (selectedRange == "30days" && summary.StudyTrends.Any(t => t.Value > 0))
                        {
                            <div class="heatmap-legend d-flex align-items-center gap-2">
                                <span class="text-white opacity-40 small">Az</span>
                                <div class="heatmap-legend-cells">
                                    <div class="heatmap-cell" style="background: rgba(59,130,246,0.15)"></div>
                                    <div class="heatmap-cell" style="background: rgba(59,130,246,0.4)"></div>
                                    <div class="heatmap-cell" style="background: rgba(59,130,246,0.7)"></div>
                                    <div class="heatmap-cell" style="background: #3b82f6"></div>
                                </div>
                                <span class="text-white opacity-40 small">Çok</span>
                            </div>
                        }
                        else if (selectedRange == "3months" && summary.StudyTrends.Any(t => t.Value > 0))
                        {
                            <div class="trend-avg-badge"><i class="bi bi-activity me-1"></i>Ortalama @Thousands(MonthlyTrendData().Avg) dk</div>
                        }
                    </div>

                    @if (!summary.StudyTrends.Any(t => t.Value > 0))
                    {
                        <div class="d-flex align-items-center justify-content-center text-white opacity-50" style="height: 220px;">
                            Veri yok
                        </div>
                    }
                    else if (selectedRange == "7days")
                    {
                        <!-- 7 Gün: günlük dikey bar -->
                        <div style="height: 300px; overflow: hidden; max-width: 100%;">
                            <ApexChart @key="@("trend-7days")" TItem="TimeTrendDto" Title="" Height="280" Width="@("100%")" Options="trendOptions">
                                <ApexPointSeries TItem="TimeTrendDto"
                                                 Items="summary.StudyTrends"
                                                 Name="Süre"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="@(e => e.Label)"
                                                 YValue="@(e => (decimal)Math.Round(e.Value))"
                                                 Color="#3b82f6"/>
                            </ApexChart>
                        </div>
                    }
                    else if (selectedRange == "30days")
                    {
                        // 30 Gün: takvim heatmap (günlük çalışma süresi)
                        var hmMax = summary.StudyTrends.Max(t => t.Value);
                        <div class="trend-heatmap" @key="@($"hm-{summary.StudyTrends.Count}")">
                            @foreach (var d in summary.StudyTrends)
                            {
                                var has = d.Value > 0;
                                var intensity = hmMax > 0 && has ? Math.Max(0.15, d.Value / hmMax) : 0.0;
                                var dayNum = d.Label.Split(' ').FirstOrDefault();
                                var bg = has
                                    ? $"rgba(59,130,246,{intensity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)})"
                                    : "rgba(255,255,255,0.05)";
                                <div class="trend-hm-cell @(has ? "has-data" : "")"
                                     style="background:@bg"
                                     title="@d.Label — @Math.Round(d.Value) dk">
                                    <span class="trend-hm-day">@dayNum</span>
                                    @if (has)
                                    {
                                        <span class="trend-hm-val">@FormatCompactDuration(d.Value)</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        // 3 Ay: aylık özet (özel tasarım — ortalama çizgisi, değerler, KPI'lar)
                        var mt = MonthlyTrendData();
                        var ci = System.Globalization.CultureInfo.InvariantCulture;
                        var avgRatio = mt.AxisMax > 0 ? (double)mt.Avg / mt.AxisMax : 0;
                        var avgLeftCalc = $"calc(60px + (100% - 150px) * {avgRatio.ToString("0.####", ci)})";
                        <div class="mtrend">
                            <div class="mtrend-bars">
                                <div class="mtrend-avg-label" style="left:@avgLeftCalc">Ortalama @Thousands(mt.Avg) dk</div>
                                <div class="mtrend-avgline" style="left:@avgLeftCalc"></div>
                                @foreach (var m in mt.Months)
                                {
                                    var wpct = mt.AxisMax > 0 ? (m.Value / mt.AxisMax * 100).ToString("0.##", ci) : "0";
                                    <div class="mtrend-row">
                                        <span class="mtrend-rowlabel">@m.Label</span>
                                        <div class="mtrend-track"><div class="mtrend-fill" style="width:@(wpct)%"></div></div>
                                        <span class="mtrend-rowval">@Thousands(m.Value)<span class="mtrend-unit"> dk</span></span>
                                    </div>
                                }
                            </div>
                            <div class="mtrend-xaxis">
                                @for (int t = 0; t <= mt.AxisMax; t += Math.Max(1, mt.AxisMax / 4))
                                {
                                    <span>@Thousands(t)</span>
                                }
                            </div>
                            <div class="mtrend-xlabel">Dakika</div>
                        </div>

                        <div class="mtrend-kpis">
                            <div class="mtrend-kpi">
                                <div class="mtrend-kpi-icon"><i class="bi bi-pie-chart-fill"></i></div>
                                <div class="mtrend-kpi-body">
                                    <div class="mtrend-kpi-label">Toplam</div>
                                    <div class="mtrend-kpi-val">@Thousands(mt.Total)<span class="mtrend-unit"> dk</span></div>
                                </div>
                            </div>
                            <div class="mtrend-kpi">
                                <div class="mtrend-kpi-icon"><i class="bi bi-bullseye"></i></div>
                                <div class="mtrend-kpi-body">
                                    <div class="mtrend-kpi-label">Ortalama</div>
                                    <div class="mtrend-kpi-val">@Thousands(mt.Avg)<span class="mtrend-unit"> dk</span></div>
                                </div>
                            </div>
                            <div class="mtrend-kpi">
                                <div class="mtrend-kpi-icon"><i class="bi bi-graph-up-arrow"></i></div>
                                <div class="mtrend-kpi-body">
                                    <div class="mtrend-kpi-label">En yüksek ay</div>
                                    <div class="mtrend-kpi-val">@Thousands(mt.Max)<span class="mtrend-unit"> dk</span></div>
                                    <div class="mtrend-kpi-sub">@mt.MaxMonth</div>
                                </div>
                            </div>
                        </div>

                        <div class="mtrend-foot">
                            <i class="bi bi-info-circle me-1"></i>Veriler oturum sürelerinin toplamını temsil eder.
                        </div>
                    }
                 </div>
            </div>
            <div class="col-12 col-lg-4">
                <div class="d-flex flex-column gap-3 h-100">
                    <div class="st-card flex-grow-1 d-flex align-items-center p-3">
                        <div class="icon-box bg-primary bg-opacity-10 text-primary me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="bi bi-stack fs-4"></i>
                        </div>
                        <div>
                            <div class="fs-3 fw-bold text-white">@summary.TotalSessions</div>
                            <div class="small opacity-50 text-white">Toplam Oturum</div>
                        </div>
                    </div>
                    
                     <div class="st-card flex-grow-1 d-flex align-items-center p-3">
                        <div class="icon-box bg-success bg-opacity-10 text-success me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="bi bi-stopwatch fs-4"></i>
                        </div>
                        <div>
                            <div class="fs-3 fw-bold text-white">@((int)Math.Round(summary.AverageSessionDuration)) <span class="fs-6 opacity-50 fw-normal">dk</span></div>
                            <div class="small opacity-50 text-white">Ortalama Oturum</div>
                        </div>
                    </div>

                     <div class="st-card flex-grow-1 d-flex align-items-center p-3">
                        <div class="icon-box bg-warning bg-opacity-10 text-warning me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="bi bi-calendar-check fs-4"></i>
                        </div>
                        <div>
                            <div class="fs-3 fw-bold text-white">@summary.MostProductiveDay</div>
                            <div class="small opacity-50 text-white">En Verimli Gün</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12 col-md-6">
                 <div class="st-card h-100" style="overflow: visible;">
                    <div class="card-header">
                        <span class="card-title text-white small text-uppercase fw-bold ls-1">Ders Dağılımı</span>
                    </div>
                    <div style="height: 300px; overflow: visible;">
                        @if(summary.LessonStatistics.Any())
                        {
                            <ApexChart TItem="LessonStatisticDto"
                                   Title=""
                                   Height="300" 
                                   Options="pieOptions">
                                <ApexPointSeries TItem="LessonStatisticDto"
                                                 Items="summary.LessonStatistics"
                                                 Name="Süre"
                                                 SeriesType="SeriesType.Donut"
                                                 XValue="@(e => e.LessonName)"
                                                 YValue="@(e => (decimal)Math.Round(e.TotalDurationMinutes))" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100 st-muted-text opacity-50">
                                Veri yok
                            </div>
                        }
                    </div>
                 </div>
            </div>
             <div class="col-12 col-md-6">
                 <div class="st-card h-100 peak-card">
                    @{
                        var peakWindow     = summary.PeakProductivity.FirstOrDefault(p => p.IsPeakRange);
                        var totalPeakMins  = (int)Math.Round(peakWindow?.Score ?? 0);
                        var totalMinsAll   = (int)Math.Round(summary.TotalStudyTime.TotalMinutes);
                        var peakScore      = totalMinsAll > 0 ? (int)Math.Round((double)totalPeakMins / totalMinsAll * 100) : 0;
                        var peakStartHour  = peakWindow?.Hour ?? -1;
                        var peakEndHour    = peakStartHour >= 0 ? peakStartHour + 3 : -1;
                        var inv            = System.Globalization.CultureInfo.InvariantCulture;
                        var peakLeftPct    = peakStartHour >= 0 ? (peakStartHour / 24.0 * 100).ToString("0.##", inv) : "0";
                        var peakWidthPct   = peakStartHour >= 0 ? ((peakEndHour - peakStartHour) / 24.0 * 100).ToString("0.##", inv) : "0";
                    }
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span class="card-title text-white small text-uppercase fw-bold ls-1">En Verimli Aralık</span>
                        @if (peakWindow != null && peakWindow.Score > 0)
                        {
                            <span class="peak-badge">
                                <i class="bi bi-lightning-fill me-1"></i>@peakWindow.Label
                            </span>
                        }
                    </div>

                    <div class="peak-body">
                        @if (peakWindow != null && peakWindow.Score > 0)
                        {
                            <div class="peak-hero">
                                <div class="peak-hero-range">@peakWindow.Label</div>
                                <div class="peak-hero-sub">En verimli çalışma aralığın</div>
                            </div>

                            <div class="peak-stats">
                                <div class="peak-stat">
                                    <div class="peak-stat-icon"><i class="bi bi-clock"></i></div>
                                    <div>
                                        <div class="peak-stat-label">Toplam Odak</div>
                                        <div class="peak-stat-value">@totalPeakMins <span class="peak-stat-unit">dk</span></div>
                                    </div>
                                </div>
                                <div class="peak-stat-divider"></div>
                                <div class="peak-stat">
                                    <div class="peak-stat-icon"><i class="bi bi-bullseye"></i></div>
                                    <div>
                                        <div class="peak-stat-label">Yoğunluk</div>
                                        <div class="peak-stat-value">%@peakScore</div>
                                    </div>
                                </div>
                            </div>

                            <div class="peak-track-wrap">
                                <div class="peak-track">
                                    <div class="peak-track-fill" style="left:@(peakLeftPct)%;width:@(peakWidthPct)%;"></div>
                                </div>
                                <div class="peak-track-ticks">
                                    <span>00:00</span><span>06:00</span><span>12:00</span><span>18:00</span><span>24:00</span>
                                </div>
                            </div>

                            <div class="peak-foot">
                                <i class="bi bi-info-circle me-1"></i>Verilerine göre bu aralıkta en yüksek odaklanma sağlıyorsun.
                            </div>
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100 st-muted-text opacity-50">
                                <i class="bi bi-clock me-2"></i> Henüz yeterli veri yok
                            </div>
                        }
                    </div>
                 </div>
            </div>
        </div>

        <div class="st-card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center gap-3">
                <span class="card-title text-white small text-uppercase fw-bold ls-1">En Uzun Süren Görevler (Top 5)</span>
                <span class="badge bg-secondary bg-opacity-25 text-white flex-shrink-0">Süreye göre</span>
            </div>
            <div class="top-task-list">
                @if (summary.TaskStatistics.Any())
                {
                    @foreach (var task in summary.TaskStatistics)
                    {
                        <div class="top-task-item">
                            <div class="top-task-icon @(task.IsCompleted ? "done" : "pending")">
                                <i class="bi @(task.IsCompleted ? "bi-check-lg" : "bi-hourglass-split")"></i>
                            </div>
                            <div class="top-task-body">
                                <div class="top-task-title">@task.Title</div>
                                <div class="top-task-meta">@task.LessonName</div>
                            </div>
                            <div class="top-task-dur">@Math.Round(task.DurationMinutes)<span class="top-task-unit"> dk</span></div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-4 text-white opacity-50">Kayıt bulunamadı</div>
                }
            </div>
        </div>

    }
</div>

@code {
    private StatisticsSummaryDto? summary;
    private bool isLoading = true;
    private string selectedRange = "7days";

    private ApexChartOptions<TimeTrendDto> trendOptions = new();   // 7 Gün: dikey bar
    private ApexChartOptions<LessonStatisticDto> pieOptions = new(); // Ders Dağılımı: donut
    // (3 Ay ve En Verimli Aralık artık özel HTML/CSS — ayrı ApexChart options yok)

    protected override async Task OnInitializedAsync()
    {
        selectedRange = "7days"; // Default filtre garanti
        GlobalTimerService.OnTimerFinished += OnSessionOrSyncRefresh;
        GlobalTimerService.OnBreakFinished += OnSessionOrSyncRefresh;
        GlobalTimerService.OnTimerStopped += OnSessionOrSyncRefresh;
        SyncStatusService.OnChange += OnSessionOrSyncRefresh;

        ConfigureCharts();
        await LoadData();
    }

    /// <summary>
    /// 3 Ay görünümü için günlük seriyi AYLIK toplar ve SON 3 AYI döndürür
    /// (bulunulan ay + önceki 2). Tüm aralığı temsil eder ama ekranı doldurmaz.
    /// Label "dd MMM" formatında olduğundan ay adı (MMM) ile gruplanır, sıra korunur.
    /// </summary>
    private List<TimeTrendDto> GetTrendDisplay()
    {
        var src = summary?.StudyTrends ?? new List<TimeTrendDto>();
        if (src.Count == 0) return src;

        var monthly = new List<TimeTrendDto>();
        foreach (var t in src)
        {
            var idx = t.Label.IndexOf(' ');
            var month = idx >= 0 ? t.Label.Substring(idx + 1) : t.Label;
            var existing = monthly.FirstOrDefault(m => m.Label == month);
            if (existing == null)
                monthly.Add(new TimeTrendDto { Label = month, Value = t.Value });
            else
                existing.Value += t.Value;
        }
        // Bu ay dahil son 3 ay.
        return monthly.Count > 3 ? monthly.Skip(monthly.Count - 3).ToList() : monthly;
    }

    /// <summary>3 Ay görünümü için aylık özet + istatistikler (tamamı StudyTrends'ten hesaplanır).</summary>
    private (List<TimeTrendDto> Months, int Total, int Avg, int Max, string MaxMonth, string Range, int AxisMax) MonthlyTrendData()
    {
        var months = GetTrendDisplay();
        int total = (int)months.Sum(m => m.Value);
        int avg = months.Count > 0 ? (int)Math.Round(months.Average(m => m.Value)) : 0;
        var maxItem = months.Count > 0 ? months.Aggregate((a, b) => b.Value > a.Value ? b : a) : null;
        int max = (int)Math.Round(maxItem?.Value ?? 0);
        string maxMonth = maxItem != null ? FullMonthName(maxItem.Label) : "-";
        int axisMax = Math.Max(2000, (int)(Math.Ceiling(max / 2000.0) * 2000));

        var tr = new System.Globalization.CultureInfo("tr-TR");
        var now = DateTime.Now;
        int span = Math.Max(months.Count, 1);
        var start = new DateTime(now.Year, now.Month, 1).AddMonths(-(span - 1));
        var end = new DateTime(now.Year, now.Month, 1).AddMonths(1).AddDays(-1);
        string range = $"{start.ToString("d MMMM", tr)} – {end.ToString("d MMMM yyyy", tr)}";

        return (months, total, avg, max, maxMonth, range, axisMax);
    }

    private static string FullMonthName(string abbr) => abbr switch
    {
        "Oca" => "Ocak", "Şub" => "Şubat", "Mar" => "Mart", "Nis" => "Nisan",
        "May" => "Mayıs", "Haz" => "Haziran", "Tem" => "Temmuz", "Ağu" => "Ağustos",
        "Eyl" => "Eylül", "Eki" => "Ekim", "Kas" => "Kasım", "Ara" => "Aralık", _ => abbr
    };

    private static string Thousands(double v) => v.ToString("N0", new System.Globalization.CultureInfo("tr-TR"));

    /// <summary>Heatmap hücresi için kısa süre etiketi: "45dk", "2s", "2.5s".</summary>
    private static string FormatCompactDuration(double minutes)
    {
        int m = (int)Math.Round(minutes);
        if (m < 60) return $"{m}dk";
        double h = m / 60.0;
        var hStr = Math.Abs(h - Math.Round(h)) < 0.05
            ? Math.Round(h).ToString(System.Globalization.CultureInfo.InvariantCulture)
            : h.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
        return hStr + "s";
    }

    private void OnSessionOrSyncRefresh()
    {
        // Arka plan tazelemesi: spinner gösterme (sessiz güncelle).
        InvokeAsync(async () =>
        {
            await LoadData(showSpinner: false);
        });
    }

    public void Dispose()
    {
        GlobalTimerService.OnTimerFinished -= OnSessionOrSyncRefresh;
        GlobalTimerService.OnBreakFinished -= OnSessionOrSyncRefresh;
        GlobalTimerService.OnTimerStopped -= OnSessionOrSyncRefresh;
        SyncStatusService.OnChange -= OnSessionOrSyncRefresh;
    }

    private async Task SetRange(string range)
    {
        selectedRange = range;
        await LoadData();
    }

    private async Task LoadData(bool showSpinner = true)
    {
        // Spinner YALNIZ ilk yükleme + filtre değişiminde gösterilir. Arka plan
        // tazelemeleri (timer/sync olayları) sessiz güncellenir; aksi halde sayfa
        // sürekli "loading" çakar.
        if (showSpinner)
        {
            isLoading = true;
            StateHasChanged();
        }
        try
        {
            summary = await StatisticsService.GetStatisticsAsync(selectedRange);
        }
        catch(Exception ex)
        {
            Console.WriteLine(ex);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void ConfigureCharts()
    {
        // Trend — zoom kapat, tam genişlik, sabit küçük yükseklik
        trendOptions.Chart = new Chart
        {
            Toolbar = new Toolbar { Show = false },
            Background = "transparent",
            ForeColor = "#94a3b8",
            Width = "100%",
            ParentHeightOffset = 0,
            Zoom = new Zoom { Enabled = false },
            // Mobilde akicilik icin animasyon kapali.
            Animations = new Animations { Enabled = false }
        };
        trendOptions.Theme = new Theme { Mode = Mode.Dark };
        trendOptions.Stroke = new Stroke { Curve = Curve.Smooth, Width = 2 };
        trendOptions.Grid = new Grid { Show = true, BorderColor = "#374151", StrokeDashArray = 4, Padding = new Padding { Left = 12, Right = 8, Bottom = 0 } };
        // Barlari biraz inceltip eksenden uzaklastir (ilk bar Y etiketlerine yapismasin).
        trendOptions.PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { ColumnWidth = "55%", BorderRadius = 4 } };
        // Y ekseni dakika birimiyle etiketlensin.
        trendOptions.Yaxis = new List<YAxis>
        {
            new YAxis
            {
                Labels = new YAxisLabels
                {
                    Style = new AxisLabelStyle { Colors = "#cbd5e1", FontSize = "11px" },
                    Formatter = "function (v) { return Math.round(v) + ' dk'; }"
                }
            }
        };
        trendOptions.Xaxis = new XAxis {
            AxisBorder = new AxisBorder { Show = false },
            AxisTicks = new AxisTicks { Show = false },
            Labels = new XAxisLabels {
                Style = new AxisLabelStyle { Colors = "#cbd5e1", FontSize = "12px" },
                Rotate = 0
            }
        };
        trendOptions.Fill = new Fill { Type = FillType.Gradient, Gradient = new FillGradient { ShadeIntensity = 1, OpacityFrom = 0.4, OpacityTo = 0.05, Stops = new List<double> { 0, 100 } } };
        trendOptions.Tooltip = new Tooltip { Theme = Mode.Dark };
        // Responsive: büyük breakpoint ile MAUI'de her çözünürlükte küçük yükseklik garantile
        trendOptions.Responsive = new List<Responsive<TimeTrendDto>> 
        { 
            new Responsive<TimeTrendDto> 
            { 
                Breakpoint = 3000, 
                Options = new ApexChartOptions<TimeTrendDto> 
                { 
                    Chart = new Chart { Height = 280, Width = "100%" },
                    Xaxis = new XAxis
                    {
                        Labels = new XAxisLabels
                        {
                            Show = true,
                            Rotate = 0,
                            Style = new AxisLabelStyle { Colors = "#cbd5e1", FontSize = "11px" }
                        }
                    }
                } 
            },
            new Responsive<TimeTrendDto>
            {
                Breakpoint = 480,
                Options = new ApexChartOptions<TimeTrendDto>
                {
                    Xaxis = new XAxis {
                        Labels = new XAxisLabels { Show = true, Rotate = 0, Style = new AxisLabelStyle { Colors = "#cbd5e1", FontSize = "10px" } }
                    }
                }
            }
        };

        pieOptions.Chart = new Chart { Toolbar = new Toolbar { Show = false }, Background = "transparent", ForeColor = "#94a3b8", Width = "100%", ParentHeightOffset = 0, Zoom = new Zoom { Enabled = false } };
        pieOptions.Theme = new Theme { Mode = Mode.Dark, Palette = PaletteType.Palette1 };
        pieOptions.Stroke = new Stroke { Show = false };
        // Legend'da ders adının yaninda TOPLAM SURE goster (dilime dokunmaya gerek kalmadan).
        pieOptions.Legend = new Legend
        {
            Position = LegendPosition.Bottom,
            HorizontalAlign = Align.Center,
            Formatter = "function(seriesName, opts){ return seriesName + ' — ' + Math.round(opts.w.globals.series[opts.seriesIndex]) + ' dk'; }"
        };
        pieOptions.PlotOptions = new PlotOptions { Pie = new PlotOptionsPie { Donut = new PlotOptionsDonut { Size = "70%" } } };
        pieOptions.Tooltip = new Tooltip { Theme = Mode.Dark, Y = new TooltipY { Formatter = @"function(val) { return Math.round(val) + ' dk' }" } };
        pieOptions.Responsive = new List<Responsive<LessonStatisticDto>>
        {
            new Responsive<LessonStatisticDto>
            {
                Breakpoint = 3000,
                Options = new ApexChartOptions<LessonStatisticDto>
                {
                    Chart = new Chart { Height = 260, Width = "100%" },
                    Legend = new Legend
                    {
                        Position = LegendPosition.Bottom,
                        Formatter = "function(seriesName, opts){ return seriesName + ' — ' + Math.round(opts.w.globals.series[opts.seriesIndex]) + ' dk'; }"
                    }
                }
            },
            new Responsive<LessonStatisticDto>
            {
                Breakpoint = 480,
                Options = new ApexChartOptions<LessonStatisticDto>
                {
                    // Dar ekranda legend'i GIZLEME; alta kucuk fontla al ki
                    // hangi rengin hangi ders + toplam suresi anlasilabilsin.
                    Legend = new Legend
                    {
                        Show = true,
                        Position = LegendPosition.Bottom,
                        HorizontalAlign = Align.Center,
                        FontSize = "10px",
                        ItemMargin = new LegendItemMargin { Horizontal = 6, Vertical = 2 },
                        Formatter = "function(seriesName, opts){ return seriesName + ' — ' + Math.round(opts.w.globals.series[opts.seriesIndex]) + ' dk'; }"
                    }
                }
            }
        };

    }
}

