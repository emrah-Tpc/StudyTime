@page "/statistics"
@using StudyTime.Application.DTOs.Statistics
@using StudyTime.DesktopClient.Services
@using StudyTime.DesktopClient.Components.Charts
@using ApexCharts
@inject StatisticsApiService StatisticsService

<div class="statistics-container fade-in">
    <div class="header-section mb-4">
        <div>
            <h1 class="text-2xl fw-bold text-white m-0">İstatistikler</h1>
            <p class="text-white opacity-75 small m-0">Çalışma verilerini analiz et</p>
        </div>

        <div class="header-actions">
            @foreach (var r in new[] { "7days", "30days", "3months" })
            {
               <button class="btn-outline @(selectedRange == r ? "active" : "")" 
                       @onclick="() => SetRange(r)">
                   @(r == "7days" ? "7 Gün" : r == "30days" ? "30 Gün" : "3 Ay")
               </button>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center align-items-center" style="height: 60vh;">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else if (summary != null)
    {
        <!-- ROW 1: Trend Chart (Reduced Height) & New Metric Cards -->
        <div class="row g-3 mb-4">
            <div class="col-12 col-lg-8">
                 <div class="st-card h-100">
                    <div class="card-header py-2">
                        <span class="card-title text-white small text-uppercase fw-bold ls-1">Çalışma Geçmişi</span>
                    </div>
                    <div style="height: 220px;"> <!-- Reduced Height -->
                        @if(summary.StudyTrends.Any())
                        {
                             <ApexChart TItem="TimeTrendDto"
                                   Title=""
                                   Height="200" 
                                   Options="trendOptions">
                                <ApexPointSeries TItem="TimeTrendDto"
                                                 Items="summary.StudyTrends"
                                                 Name="Süre (dk)"
                                                 SeriesType="SeriesType.Area"
                                                 XValue="@(e => e.Label)"
                                                 YValue="@(e => (decimal)e.Value)"
                                                 Color="#3b82f6"/>
                            </ApexChart>
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100 text-white opacity-50">
                                Veri yok
                            </div>
                        }
                    </div>
                 </div>
            </div>
            <div class="col-12 col-lg-4">
                <div class="d-flex flex-column gap-3 h-100">
                    <!-- New Metric: Total Sessions -->
                    <div class="st-card flex-grow-1 d-flex align-items-center p-3">
                        <div class="icon-box bg-primary bg-opacity-10 text-primary me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="bi bi-stack fs-4"></i>
                        </div>
                        <div>
                            <div class="fs-3 fw-bold text-white">@summary.TotalSessions</div>
                            <div class="small opacity-50 text-white">Toplam Oturum</div>
                        </div>
                    </div>
                    
                    <!-- New Metric: Average Session Duration -->
                     <div class="st-card flex-grow-1 d-flex align-items-center p-3">
                        <div class="icon-box bg-success bg-opacity-10 text-success me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="bi bi-stopwatch fs-4"></i>
                        </div>
                        <div>
                            <div class="fs-3 fw-bold text-white">@summary.AverageSessionDuration <span class="fs-6 opacity-50 fw-normal">dk</span></div>
                            <div class="small opacity-50 text-white">Ortalama Oturum</div>
                        </div>
                    </div>

                    <!-- New Metric: Most Productive Day -->
                     <div class="st-card flex-grow-1 d-flex align-items-center p-3">
                        <div class="icon-box bg-warning bg-opacity-10 text-warning me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="bi bi-calendar-check fs-4"></i>
                        </div>
                        <div>
                            <div class="fs-3 fw-bold text-white">@summary.MostProductiveDay</div>
                            <div class="small opacity-50 text-white">En Verimli Gün</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ROW 2: Lesson Distribution & Peak Productivity -->
        <div class="row g-3 mb-4">
            <div class="col-12 col-md-6">
                 <div class="st-card h-100">
                    <div class="card-header">
                        <span class="card-title text-white small text-uppercase fw-bold ls-1">Ders Dağılımı</span>
                    </div>
                    <div style="height: 300px;">
                        @if(summary.LessonStatistics.Any())
                        {
                            <ApexChart TItem="LessonStatisticDto"
                                   Title=""
                                   Height="300" 
                                   Options="pieOptions">
                                <ApexPointSeries TItem="LessonStatisticDto"
                                                 Items="summary.LessonStatistics"
                                                 Name="Süre"
                                                 SeriesType="SeriesType.Donut"
                                                 XValue="@(e => e.LessonName)"
                                                 YValue="@(e => (decimal)e.TotalDurationMinutes)" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100 text-white opacity-50">
                                Veri yok
                            </div>
                        }
                    </div>
                 </div>
            </div>
            <div class="col-12 col-md-6">
                 <div class="st-card h-100">
                    <div class="card-header">
                        <span class="card-title text-white small text-uppercase fw-bold ls-1">En Verimli Saatler</span>
                    </div>
                    <div style="height: 300px;">
                         @if(summary.PeakProductivity.Any())
                        {
                            <!-- Improved Bar Chart with Color Scale logic in Options or just better basic styling -->
                            <ApexChart TItem="ProductivityDto"
                                   Title=""
                                   Height="280"
                                   Options="barOptions">
                                <ApexPointSeries TItem="ProductivityDto"
                                                 Items="summary.PeakProductivity"
                                                 Name="Verimlilik (dk)"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="@(e => $"{e.Hour:00}:00")"
                                                 YValue="@(e => (decimal)e.Score)"
                                                 Color="#10b981"/> <!-- Static color for now, advanced color scale requires complex JS/Options -->
                            </ApexChart>
                        }
                        else
                        {
                             <div class="d-flex align-items-center justify-content-center h-100 text-white opacity-50">
                                Veri yok
                            </div>
                        }
                    </div>
                 </div>
            </div>
        </div>

        <!-- ROW 3: Top 5 Tasks (Styled) -->
        <div class="st-card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="card-title text-white small text-uppercase fw-bold ls-1">En Uzun Süren Görevler (Top 5)</span>
                <span class="badge bg-secondary bg-opacity-25 text-white">Tamamlanan</span>
            </div>
            <div class="table-responsive">
                <table class="table table-dark table-borderless table-hover align-middle mb-0" style="background: transparent;">
                    <thead class="border-bottom border-secondary border-opacity-25">
                        <tr>
                            <th class="text-white opacity-50 fw-normal py-3 ps-4" style="background-color: transparent;">GÖREV</th>
                            <th class="text-white opacity-50 fw-normal py-3" style="background-color: transparent;">DERS</th>
                            <th class="text-white opacity-50 fw-normal py-3 text-end pe-4" style="background-color: transparent;">SÜRE</th>
                        </tr>
                    </thead>
                    <tbody style="border-top: none;">
                        @if(summary.TaskStatistics.Any())
                        {
                            @foreach(var task in summary.TaskStatistics)
                            {
                                <tr style="background-color: transparent;">
                                    <td class="ps-4" style="background-color: transparent;">
                                        <div class="d-flex align-items-center">
                                            <div class="rounded-circle bg-success bg-opacity-25 p-1 me-3 d-flex justify-content-center align-items-center" style="width: 24px; height: 24px;">
                                                <i class="bi bi-check text-success small"></i>
                                            </div>
                                            <span class="text-white fw-medium">@task.Title</span>
                                        </div>
                                    </td>
                                    <td style="background-color: transparent;">
                                        <span class="badge bg-dark border border-secondary border-opacity-25 text-white fw-normal px-3 py-2 rounded-pill">
                                            @task.LessonName
                                        </span>
                                    </td>
                                    <td class="text-end pe-4" style="background-color: transparent;">
                                        <span class="text-white fw-bold font-monospace">@Math.Round(task.DurationMinutes) dk</span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center py-4 text-white opacity-50" style="background-color: transparent;">
                                    Kayıt bulunamadı
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private StatisticsSummaryDto? summary;
    private bool isLoading = true;
    private string selectedRange = "7days";

    private ApexChartOptions<TimeTrendDto> trendOptions = new();
    private ApexChartOptions<LessonStatisticDto> pieOptions = new();
    private ApexChartOptions<ProductivityDto> barOptions = new();

    protected override async Task OnInitializedAsync()
    {
        ConfigureCharts();
        await LoadData();
    }

    private async Task SetRange(string range)
    {
        selectedRange = range;
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            summary = await StatisticsService.GetStatisticsAsync(selectedRange);
        }
        catch(Exception ex)
        {
            Console.WriteLine(ex);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ConfigureCharts()
    {
        // TREND CHART
        trendOptions.Chart = new Chart { Toolbar = new Toolbar { Show = false }, Background = "transparent", ForeColor = "#94a3b8" };
        trendOptions.Theme = new Theme { Mode = Mode.Dark };
        trendOptions.Stroke = new Stroke { Curve = Curve.Smooth, Width = 3 };
        trendOptions.Grid = new Grid { Show = true, BorderColor = "#374151", StrokeDashArray = 4 };
        trendOptions.Xaxis = new XAxis { 
            AxisBorder = new AxisBorder { Show = false }, 
            AxisTicks = new AxisTicks { Show = false },
            Labels = new XAxisLabels { Style = new AxisLabelStyle { Colors = "#94a3b8" } }
        };
        trendOptions.Fill = new Fill { Type = FillType.Gradient, Gradient = new FillGradient { ShadeIntensity = 1, OpacityFrom = 0.5, OpacityTo = 0.1, Stops = new List<double> { 0, 100 } } };

        // PIE CHART
        pieOptions.Chart = new Chart { Toolbar = new Toolbar { Show = false }, Background = "transparent", ForeColor = "#94a3b8" };
        pieOptions.Theme = new Theme { Mode = Mode.Dark, Palette = PaletteType.Palette1 };
        pieOptions.Stroke = new Stroke { Show = false };
        pieOptions.Legend = new Legend { Position = LegendPosition.Bottom, HorizontalAlign = Align.Center };
        pieOptions.PlotOptions = new PlotOptions { Pie = new PlotOptionsPie { Donut = new PlotOptionsDonut { Size = "70%" } } };

        // BAR CHART (Peak Productivity)
        barOptions.Chart = new Chart { Toolbar = new Toolbar { Show = false }, Background = "transparent", ForeColor = "#94a3b8" };
        barOptions.Theme = new Theme { Mode = Mode.Dark };
        barOptions.Grid = new Grid { Show = false };
        barOptions.Xaxis = new XAxis { 
            AxisBorder = new AxisBorder { Show = false }, 
            AxisTicks = new AxisTicks { Show = false },
            Labels = new XAxisLabels {  Rotate = -45, Style = new AxisLabelStyle { Colors = "#94a3b8", FontSize = "10px" } }
        };
        barOptions.PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { BorderRadius = 2, ColumnWidth = "70%" } };
        // Improve tooltip
        barOptions.Tooltip = new Tooltip { Theme = Mode.Dark, Y = new TooltipY { Formatter = @"function(val) { return val + ' dk' }" } };
    }
}
