@inherits TasksBase
@using StudyTime.Application.DTOs.Tasks
@using StudyTime.Application.DTOs.Lessons
@using System.Globalization

<div class="calendar-container fade-in mobile-tasks">
    <!-- Header -->
    <div class="calendar-header mb-4 d-flex flex-column gap-3">
        <div class="d-flex justify-content-between align-items-center w-100">
            <div>
                <h1 class="text-xl fw-bold text-white m-0">Görevler</h1>
            </div>
            <button class="btn-primary btn-sm" @onclick="GoToToday">Bugün</button>
        </div>
        <div class="d-flex align-items-center justify-content-center gap-3 w-100">
             <button class="btn-icon-sm" @onclick="PreviousMonth"><i class="bi bi-chevron-left"></i></button>
             <span class="fs-5 fw-bold text-white" style="text-align: center;">@CurrentMonthName @CurrentYear</span>
             <button class="btn-icon-sm" @onclick="NextMonth"><i class="bi bi-chevron-right"></i></button>
        </div>
    </div>

    <!-- Calendar Grid -->
    <!-- Agenda View Grid -->
    <div class="calendar-grid">
        @if (isLoading)
        {
             @for (int i = 0; i < 5; i++)
             {
                 <div class="calendar-cell skeleton-cell"></div>
             }
        }
        else
        {
            @foreach (var day in CalendarDays.Where(d => d.IsCurrentMonth && d.Tasks.Any()))
            {
                <div class="calendar-cell @(IsToday(day.Date) ? "today" : "")"
                     style="border-left: 4px solid @GetHeatmapColor(day.Tasks.Count);"
                     @onclick="() => SelectDay(day)">
                    
                    <div class="cell-header d-flex flex-column align-items-center justify-content-center">
                        <span class="day-number">@day.Date.Day</span>
                        <span class="day-name" style="font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase;">
                            @CurrentCulture.DateTimeFormat.GetAbbreviatedDayName(day.Date.DayOfWeek)
                        </span>
                    </div>

                    <div class="cell-content flex-grow-1 ms-3">
                        <div class="fw-bold text-white mb-1" style="font-size: 0.95rem;">
                            @day.Tasks.Count Görev
                        </div>
                        <div class="text-truncate text-white opacity-50 small" style="max-width: 200px;">
                            @string.Join(", ", day.Tasks.Select(t => t.Title))
                        </div>
                    </div>
                    
                    <i class="bi bi-chevron-right text-muted"></i>
                </div>
            }

            @if (!CalendarDays.Any(d => d.IsCurrentMonth && d.Tasks.Any()))
            {
                <div class="text-center py-5 text-white opacity-50">
                    <i class="bi bi-calendar-check fs-1 mb-2"></i>
                    <p>Bu ay için planlanmış görev yok.</p>
                </div>
            }
        }
    </div>
</div>

<!-- Task Detail Modal -->
@if (selectedDay != null)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down">
            <div class="modal-content custom-modal" style="border-radius: 16px 16px 0 0; min-height: 50vh;">
                <div class="modal-header border-0">
                    <div>
                        <h5 class="modal-title fw-bold text-white">@selectedDay.Date.ToString("dd MMMM dddd", CurrentCulture)</h5>
                         <span class="text-white opacity-50 small">@selectedDay.Tasks.Count Görev</span>
                    </div>
                    <button type="button" class="modal-close-adaptive" @onclick="CloseModal" aria-label="Kapat">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div class="modal-body" style="overflow-y: auto;">
                    @if (selectedDay.Tasks.Any())
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var task in selectedDay.Tasks)
                            {
                                var lessonColor = task.Lesson?.Color ?? "var(--accent-blue)";
                                <div class="st-card p-3 d-flex flex-column gap-2" style="border-left: 4px solid @lessonColor; position: relative;">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="form-check m-0">
                                                <input class="form-check-input" type="checkbox" checked="@IsTaskCompleted(task)"
                                                       disabled="@IsTaskCompleted(task)"
                                                       @onchange="(e) => ToggleTaskStatus(task, e.Value)">
                                            </div>
                                            <div>
                                                <div class="fw-medium text-white @(IsTaskCompleted(task) ? "text-decoration-line-through opacity-50" : "")" style="font-size: 1.05rem;">
                                                    @task.Title
                                                </div>
                                                <div class="small fw-medium mt-1" style="color: @lessonColor;">
                                                    <i class="bi bi-circle-fill me-1" style="font-size: 8px;"></i>@(task.Lesson?.Name ?? "Genel")
                                                </div>
                                            </div>
                                        </div>
                                        <button class="btn btn-sm btn-icon-only stretched-link" style="color: var(--text-dim);" 
                                                @onclick="() => selectedDetailTask = task">
                                            <i class="bi bi-chevron-right"></i>
                                        </button>
                                    </div>
                                    
                                    @if (!string.IsNullOrWhiteSpace(task.Note) || task.PlannedDuration.HasValue || task.EndDate.HasValue)
                                    {
                                        <div class="mt-1 ms-5 ps-1 d-flex flex-column gap-2">
                                            @if (!string.IsNullOrWhiteSpace(task.Note))
                                            {
                                                <div class="small text-white opacity-50 text-truncate" style="max-width: 90%;">
                                                    <i class="bi bi-text-paragraph me-1"></i> @task.Note
                                                </div>
                                            }
                                            <div class="d-flex gap-2 flex-wrap">
                                                @if (task.PlannedDuration.HasValue)
                                                {
                                                    <span class="badge" style="background: rgba(255,255,255,0.08); color: var(--text-muted); font-weight: 500;">
                                                        <i class="bi bi-clock me-1"></i> @GetFormattedDuration(task.PlannedDuration.Value)
                                                    </span>
                                                }
                                                @if (task.EndDate.HasValue)
                                                {
                                                    <span class="badge" style="background: rgba(255,255,255,0.08); color: var(--text-muted); font-weight: 500;">
                                                        <i class="bi bi-calendar-check me-1"></i> Bitiş: @task.EndDate.Value.ToString("dd MMM HH:mm", CurrentCulture)
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-white opacity-50">
                            <i class="bi bi-calendar-x fs-1 mb-2"></i>
                            <p>Bugün için planlanmış görev yok.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Alt Görev Detay Modalı -->
@if (selectedDetailTask != null)
{
    <div class="modal-backdrop fade show" style="z-index: 1060;"></div>
    <div class="modal fade show d-block" tabindex="-1" style="z-index: 1065;">
        <div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down">
            <div class="modal-content border-0 shadow-lg" style="background: linear-gradient(145deg, #2b2b2b, #1f1f1f); border-radius: 16px 16px 0 0; min-height: 60vh;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold text-white d-flex align-items-center">
                        <i class="bi bi-list-task me-2" style="color: @(selectedDetailTask.Lesson?.Color ?? "#fff")"></i> 
                        <span style="font-size: 1.1rem; line-height: 1.2;">@selectedDetailTask.Title</span>
                    </h5>
                    <button type="button" class="modal-close-adaptive" @onclick="() => selectedDetailTask = null" aria-label="Kapat">
                        <i class="bi bi-arrow-left"></i>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="p-3 mb-3" style="background: rgba(255,255,255,0.05); border-radius: 8px;">
                        <h6 class="text-white opacity-75 small text-uppercase mb-2"><i class="bi bi-card-text me-1"></i>Açıklama</h6>
                        <p class="text-white m-0" style="font-size: 0.95rem; white-space: pre-wrap;">
                            @(string.IsNullOrWhiteSpace(selectedDetailTask.Note) ? "Bu görev için açıklama bulunmuyor." : selectedDetailTask.Note)
                        </p>
                    </div>

                    <div class="row g-2">
                         <div class="col-6">
                            <div class="p-2 h-100" style="background: rgba(255,255,255,0.03); border-radius: 8px;">
                                <div class="text-white opacity-50 small mb-1"><i class="bi bi-clock-history"></i> Süre</div>
                                <div class="fw-bold text-white fs-6">
                                    @(selectedDetailTask.PlannedDuration.HasValue ? GetFormattedDuration(selectedDetailTask.PlannedDuration.Value) : "-")
                                </div>
                            </div>
                         </div>
                         <div class="col-6">
                            <div class="p-2 h-100" style="background: rgba(255,255,255,0.03); border-radius: 8px;">
                                <div class="text-white opacity-50 small mb-1"><i class="bi bi-tag"></i> Ders</div>
                                <div class="fw-bold fs-6" style="color: @(selectedDetailTask.Lesson?.Color ?? "#fff")">
                                    @(selectedDetailTask.Lesson?.Name ?? "Genel")
                                </div>
                            </div>
                         </div>
                         <div class="col-12 mt-2">
                             <div class="d-flex justify-content-between p-2" style="background: rgba(255,255,255,0.03); border-radius: 8px;">
                                 <div>
                                     <div class="text-white opacity-50 small">Başlangıç</div>
                                     <div class="text-white small fw-medium mt-1">@(selectedDetailTask.StartDate?.ToString("dd MMM HH:mm", CurrentCulture) ?? "-")</div>
                                 </div>
                                 <div class="text-end">
                                     <div class="text-white opacity-50 small">Bitiş</div>
                                     <div class="text-white small fw-medium mt-1">@(selectedDetailTask.EndDate?.ToString("dd MMM HH:mm", CurrentCulture) ?? "-")</div>
                                 </div>
                             </div>
                         </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
<style>
    .calendar-grid {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .calendar-cell {
        background-color: var(--bg-card);
        min-height: 70px;
        padding: 12px 16px;
        cursor: pointer;
        transition: transform 0.2s, background-color 0.2s;
        border-radius: 12px;
        border: 1px solid var(--border-color);
        display: flex;
        align-items: center;
    }

    .calendar-cell:active {
        transform: scale(0.98);
        background-color: rgba(255, 255, 255, 0.05);
    }

    .calendar-cell.today {
        border-color: var(--accent-blue);
        background-color: rgba(59, 130, 246, 0.05);
    }

    .skeleton-cell {
        background-color: var(--bg-surface);
        animation: pulse 1.5s infinite;
        border: none;
    }
    
    @@keyframes pulse {
        0% { opacity: 0.6; }
        50% { opacity: 1; }
        100% { opacity: 0.6; }
    }

    .cell-header {
        min-width: 40px;
    }

    .day-number {
        font-weight: 700;
        font-size: 1.3rem;
        color: var(--text-main);
        line-height: 1;
    }

    .cell-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .modal-close-adaptive {
        background: none;
        border: none;
        font-size: 1.1rem;
        color: var(--text-main);
        opacity: 0.6;
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 6px;
        line-height: 1;
        transition: opacity 0.15s, background 0.15s;
    }
    
    /* Bottom sheet modal for mobile */
    .modal-fullscreen-sm-down {
        align-items: flex-end;
        margin: 0;
    }
</style>
