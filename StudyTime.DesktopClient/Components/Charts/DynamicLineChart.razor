@using StudyTime.Application.DTOs.Dashboard
@using System.Globalization
@using System.Text
@namespace StudyTime.DesktopClient.Components.Charts

<div class="chart-container-relative" style="width:100%; height: 250px; display:flex; flex-direction: column;">
    @if (hoveredLineData != null)
    {
        <div class="chart-tooltip" style="left: @((hoveredLineData.X + 35).ToString(CultureInfo.InvariantCulture))px; top: @((hoveredLineData.Y - 10).ToString(CultureInfo.InvariantCulture))px;">
            <div class="fw-bold">@hoveredLineData.Label</div>
            <div>@FormatValue(hoveredLineData.Value)</div>
        </div>
    }

    <div style="display:flex; flex:1;">
        <!-- Y Ekseni Değerleri -->
        <div style="width: 40px; display:flex; flex-direction:column; justify-content:space-between; color: #94a3b8; font-size: 0.7rem; text-align:right; padding-right:10px; padding-top: 10px; padding-bottom: 25px;">
            <span>@GetYAxisValue(4)</span>
            <span>@GetYAxisValue(3)</span>
            <span>@GetYAxisValue(2)</span>
            <span>@GetYAxisValue(1)</span>
            <span>0</span>
        </div>

        <div style="flex:1; position:relative;">
            <!-- ViewBox genişletildi ve padding mantığı eklendi -->
            <svg viewBox="0 0 400 200" class="line-chart" style="width:100%; height:100%; overflow:visible;" preserveAspectRatio="none">
                <defs>
                    <linearGradient id="lineGradient" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#22d3ee" stop-opacity="0.2" />
                        <stop offset="100%" stop-color="#22d3ee" stop-opacity="0" />
                    </linearGradient>
                </defs>

                <!-- Grid Çizgileri -->
                @for (int i = 0; i <= 4; i++)
                {
                    double y = Y_PADDING_TOP + (i * ((HEIGHT - Y_PADDING_TOP - Y_PADDING_BOTTOM) / 4));
                    <line x1="0" y1="@y" x2="400" y2="@y" stroke="#374151" stroke-width="1" stroke-dasharray="4 4" opacity="0.2" />
                }
                
                <!-- Dikey Rehber Çizgiler & X Ekseni Etiketleri -->
                @foreach (var point in ChartPoints)
                {
                    <line x1="@point.X.ToString(CultureInfo.InvariantCulture)" y1="@Y_PADDING_TOP" x2="@point.X.ToString(CultureInfo.InvariantCulture)" y2="@(HEIGHT - Y_PADDING_BOTTOM)" stroke="#374151" stroke-width="1" stroke-dasharray="4 4" opacity="0.1" />
                    
                    <!-- SVG içi Text Label - Razor <text> ile karışmaması için <g> içine alındı -->
                    <g>
                        <text x="@point.X.ToString(CultureInfo.InvariantCulture)" y="195" fill="#94a3b8" font-size="10" text-anchor="middle">@point.Label</text>
                    </g>
                }

                <!-- Alan Dolgusu (Opsiyonel görsel zenginlik) -->
                <path d="@GetAreaPath()" fill="url(#lineGradient)" />

                <!-- Ana Çizgi -->
                <path d="@GetSmoothPath()" fill="none" stroke="#22d3ee" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="chart-line-anim" />

                <!-- Noktalar -->
                @foreach (var point in ChartPoints)
                {
                    <circle cx="@point.X.ToString(CultureInfo.InvariantCulture)" cy="@point.Y.ToString(CultureInfo.InvariantCulture)" r="4" fill="#09090b" stroke="#22d3ee" stroke-width="2" />
                    
                    <!-- Görünmez Hit Area -->
                    <circle cx="@point.X.ToString(CultureInfo.InvariantCulture)" cy="@point.Y.ToString(CultureInfo.InvariantCulture)" r="12" fill="transparent" stroke="transparent" style="cursor:pointer;"
                            @onmouseover="() => hoveredLineData = point"
                            @onmouseout="() => hoveredLineData = null" />
                }
            </svg>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<ChartDataDto> Data { get; set; } = new();

    private ChartPoint? hoveredLineData;
    
    // Sabitler
    private const double WIDTH = 400;
    private const double HEIGHT = 180;
    private const double Y_PADDING_TOP = 10;
    private const double Y_PADDING_BOTTOM = 10; // SVG viewBox yüksekliğini 200 yaptık, 180 çizim alanı + 20 etiket

    private List<ChartPoint> ChartPoints => GetChartPoints();

    private string FormatValue(int minutes) => minutes < 60 ? $"{minutes}dk" : $"{Math.Round(minutes / 60.0, 1)}s";

    private string GetYAxisValue(int step)
    {
        if (!Data.Any()) return "0";
        double max = Data.Max(d => d.Value);
        if (max == 0) max = 10;
        
        // Max değerin %10 fazlası tavan olsun
        double ceiling = max * 1.1; 
        
        int val = (int)(ceiling * ((double)step / 4)); // Adım hesaplama (Ters mantık: step 0 en üst değil, step 4 en üst)
        // Düzeltme: Grid yukarıdan aşağı çiziliyor (0 -> Y_TOP). 
        // Etiketler aşağıdan yukarı (0 -> ..).
        // Kodun yukarısında @GetYAxisValue(4) en üstte. Demek ki step 4 = max value.
        
        return val < 60 ? val.ToString() : (val / 60).ToString();
    }

    private class ChartPoint { public double X { get; set; } public double Y { get; set; } public string Label { get; set; } = ""; public int Value { get; set; } }

    private List<ChartPoint> GetChartPoints()
    {
        if (Data == null || !Data.Any()) return new();

        var points = new List<ChartPoint>();
        
        // 1. Max Value Reset & Calculation
        double maxVal = Data.Max(d => d.Value);
        if (maxVal == 0) maxVal = 10; // 0'a bölme hatasını önle
        
        double drawingHeight = HEIGHT - Y_PADDING_TOP - Y_PADDING_BOTTOM;
        int count = Data.Count;

        // 2. Strict X-Axis Scaling Formula
        // Eğer 1 nokta varsa ortaya koy, yoksa (Width / (N-1)) kadar atla
        double xStep = count > 1 ? WIDTH / (count - 1) : WIDTH / 2;

        for (int i = 0; i < count; i++)
        {
            // X Hesaplama: Strict Formula
            double x = i * xStep;

            // Kenar düzeltmesi (Floating point hatalarını önlemek için son noktayı tam sağa yasla)
            if (count > 1 && i == count - 1) x = WIDTH;
            else if (count == 1) x = WIDTH / 2;

            // Y Hesaplama: Height - (value / max * height)
            // Ancak, padding olduğu için: (HEIGHT - PADDING_BOTTOM) - (ratio * drawingHeight)
            double ratio = (double)Data[i].Value / maxVal;
            
            // Eğer maxVal 1.1 ile çarpılarak "ceiling" yapılıyorsa, oran buna göre düşmeli.
            // Kullanıcı "new data eklendiğinde MaxValue yeniden hesapla" dedi.
            // Burada Y ekseni tavanını (Ceiling) max değerin biraz üstü yapalım ki tepeye yapışmasın.
            double ceiling = maxVal * 1.1;
            double normalizedRatio = (double)Data[i].Value / ceiling;
            
            double y = (HEIGHT - Y_PADDING_BOTTOM) - (normalizedRatio * drawingHeight);

            points.Add(new ChartPoint { X = x, Y = y, Label = Data[i].Label, Value = Data[i].Value });
        }
        return points;
    }

    private string GetSmoothPath()
    {
        var points = ChartPoints;
        if (points.Count == 0) return "";
        if (points.Count == 1) 
        {
             var p = points[0];
             return $"M {p.X.ToString(CultureInfo.InvariantCulture)} {p.Y.ToString(CultureInfo.InvariantCulture)} h 10"; 
        }

        // Monotone Cubic Spline Algorithm
        // 1. Calculate secants (slopes)
        int n = points.Count;
        double[] dx = new double[n - 1];
        double[] dy = new double[n - 1];
        double[] slopes = new double[n - 1];

        for (int i = 0; i < n - 1; i++)
        {
            dx[i] = points[i + 1].X - points[i].X;
            dy[i] = points[i + 1].Y - points[i].Y;
            slopes[i] = dy[i] / dx[i];
        }

        // 2. Initialize tangents
        double[] t = new double[n];
        
        // Boundaries
        t[0] = slopes[0];
        t[n - 1] = slopes[n - 2];

        // Internal points: Average of adjacent slopes
        for (int i = 0; i < n - 2; i++)
        {
            double m = slopes[i];
            double nextM = slopes[i + 1];
            if (m * nextM <= 0) 
            {
                t[i + 1] = 0; // Flat if slope changes direction
            }
            else 
            {
                t[i + 1] = (m + nextM) / 2.0;
            }
        }

        // 3. Monotone check (prevent overshoot)
        for (int i = 0; i < n - 1; i++)
        {
            if (dy[i] == 0)
            {
                t[i] = 0;
                t[i + 1] = 0;
            }
            else
            {
                double alpha = t[i] / slopes[i];
                double beta = t[i + 1] / slopes[i];
                double dist = alpha * alpha + beta * beta;
                if (dist > 9)
                {
                    double tau = 3.0 / Math.Sqrt(dist);
                    t[i] = tau * alpha * slopes[i];
                    t[i + 1] = tau * beta * slopes[i];
                }
            }
        }

        // 4. Generate Path
        StringBuilder path = new StringBuilder();
        path.Append($"M {points[0].X.ToString(CultureInfo.InvariantCulture)} {points[0].Y.ToString(CultureInfo.InvariantCulture)}");

        for (int i = 0; i < n - 1; i++)
        {
            double x0 = points[i].X;
            double y0 = points[i].Y;
            double x1 = points[i + 1].X;
            double y1 = points[i + 1].Y;
            
            double dist = x1 - x0;
            
            double cp1x = x0 + dist / 3.0;
            double cp1y = y0 + t[i] * dist / 3.0;
            
            double cp2x = x1 - dist / 3.0;
            double cp2y = y1 - t[i + 1] * dist / 3.0;

            path.Append($" C {cp1x.ToString(CultureInfo.InvariantCulture)} {cp1y.ToString(CultureInfo.InvariantCulture)}, {cp2x.ToString(CultureInfo.InvariantCulture)} {cp2y.ToString(CultureInfo.InvariantCulture)}, {x1.ToString(CultureInfo.InvariantCulture)} {y1.ToString(CultureInfo.InvariantCulture)}");
        }

        return path.ToString();
    }

    private string GetAreaPath()
    {
        var path = GetSmoothPath();
        if (string.IsNullOrEmpty(path)) return "";
        
        var points = ChartPoints;
        if (!points.Any()) return "";

        var last = points.Last();
        var first = points.First();
        var bottom = HEIGHT - Y_PADDING_BOTTOM;

        return $"{path} L {last.X.ToString(CultureInfo.InvariantCulture)} {bottom.ToString(CultureInfo.InvariantCulture)} L {first.X.ToString(CultureInfo.InvariantCulture)} {bottom.ToString(CultureInfo.InvariantCulture)} Z";
    }
}
