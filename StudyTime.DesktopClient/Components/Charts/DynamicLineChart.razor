@using StudyTime.Application.DTOs.Dashboard
@using ApexCharts
@namespace StudyTime.DesktopClient.Components.Charts

<div style="width: 100%; overflow: hidden;">
    <ApexChart TItem="ChartDataDto"
               Title=""
               Height="230"
               Width="@("100%")"
               @ref="chart"
               Options="options">

        <ApexPointSeries TItem="ChartDataDto"
                         Items="Data"
                         Name="Süre"
                         SeriesType="SeriesType.Area"
                         XValue="@(e => e.Label)"
                         YValue="@(e => e.Value)"
                         Color="#22d3ee" />
    </ApexChart>
</div>

@code {
    [Parameter]
    public List<ChartDataDto> Data { get; set; } = new();

    private ApexChartOptions<ChartDataDto> options { get; set; } = new();
    private ApexChart<ChartDataDto>? chart;

    protected override void OnInitialized()
    {
        options.Chart = new Chart
        {
            Toolbar = new Toolbar { Show = false },
            Selection = new Selection { Enabled = false },
            Background = "transparent",
            ForeColor = "#94a3b8", // Text color
            Zoom = new Zoom { Enabled = false },
            // Mobil WebView'de akicilik icin animasyon kapali (algilanan performans artar).
            Animations = new Animations { Enabled = false }
        };

        options.Theme = new Theme { Mode = ApexCharts.Mode.Dark };

        // Smooth curve
        options.Stroke = new Stroke { Curve = Curve.Smooth, Width = 3 };

        // Grid
        options.Grid = new Grid
        {
            Show = true,
            BorderColor = "#374151",
            StrokeDashArray = 4,
            Padding = new Padding { Left = 0, Right = 0, Top = 0, Bottom = 0 }
        };

        // X-Axis
        options.Xaxis = new XAxis
        {
            AxisBorder = new AxisBorder { Show = false },
            AxisTicks = new AxisTicks { Show = false },
            Labels = new XAxisLabels { Style = new AxisLabelStyle { Colors = "#cbd5e1", FontSize = "12px" } },
            Tooltip = new AxisTooltip { Enabled = false }
        };

        // Y-Axis: veri aralığına göre TEK birim + YUVARLAK adımlar (ConfigureYAxis).
        ConfigureYAxis();

        // Fill / Area Gradient
        options.Fill = new Fill
        {
            Type = FillType.Gradient,
            Gradient = new FillGradient
            {
                ShadeIntensity = 1,
                OpacityFrom = 0.4,
                OpacityTo = 0.05,
                Stops = new List<double> { 0, 100 }
            }
        };

        options.DataLabels = new DataLabels { Enabled = false };
        options.Theme = new Theme { Mode = ApexCharts.Mode.Dark };
        options.Tooltip = new Tooltip { Enabled = true, Theme = ApexCharts.Mode.Dark, Intersect = false, Shared = true };

        // Responsive Options
        options.Responsive = new List<Responsive<ChartDataDto>>
        {
            new Responsive<ChartDataDto>
            {
                Breakpoint = 768,
                Options = new ApexChartOptions<ChartDataDto>
                {
                    Chart = new Chart
                    {
                        Height = 220,
                        Width = "100%",
                        Toolbar = new Toolbar { Show = false }
                    },
                    Xaxis = new XAxis
                    {
                        Labels = new XAxisLabels
                        {
                            Show = true,
                            Rotate = 0,
                            Style = new AxisLabelStyle { Colors = "#cbd5e1", FontSize = "11px" }
                        },
                        TickAmount = 6
                    }
                }
            },
            new Responsive<ChartDataDto>
            {
                Breakpoint = 480,
                Options = new ApexChartOptions<ChartDataDto>
                {
                    Chart = new Chart
                    {
                        Height = 210,
                        Width = "100%",
                        Toolbar = new Toolbar { Show = false }
                    },
                    // Dar ekranda da X eksenini GIZLEME; etiketleri okunur tut.
                    Xaxis = new XAxis
                    {
                        Labels = new XAxisLabels
                        {
                            Show = true,
                            Rotate = -30,
                            RotateAlways = true,
                            HideOverlappingLabels = true,
                            Style = new AxisLabelStyle { Colors = "#cbd5e1", FontSize = "10px" }
                        },
                        TickAmount = 5
                    }
                }
            }
        };
    }

    protected override async Task OnParametersSetAsync()
    {
        ConfigureYAxis();
        if (chart != null)
        {
            // Eksen aralığı verilere göre değiştiği için önce seçenekleri, sonra seriyi güncelle.
            await chart.UpdateOptionsAsync(false, false, false);
            await chart.UpdateSeriesAsync(true);
        }
    }

    /// <summary>
    /// Y eksenini verinin maksimumuna göre TEK birimle ve YUVARLAK adımlarla kurar.
    /// Karışık "50dk → 1.7s → 2.5s" yerine ya tam saat (0s,2s,4s) ya da düzgün dakika.
    /// </summary>
    private void ConfigureYAxis()
    {
        double max = Data.Count > 0 ? Data.Max(d => d.Value) : 0;

        YAxis yaxis;
        if (max < 60)
        {
            // Dakika modu: 15'in katı, en çok 2 aralık → 0 / orta / üst
            int niceMax = Math.Max(30, (int)(Math.Ceiling(max / 15.0) * 15));
            yaxis = new YAxis
            {
                Min = 0,
                Max = niceMax,
                TickAmount = 2,
                Labels = new YAxisLabels
                {
                    Style = new AxisLabelStyle { Colors = "#cbd5e1", FontSize = "11px" },
                    Formatter = "function (v) { return Math.round(v) + 'dk'; }"
                }
            };
        }
        else
        {
            // Saat modu: eksen üstü tam saatlerin katı olacak şekilde seçilir,
            // böylece tick'ler 60'ın katına düşer ve etiketler tam saat olur (0s,2s,4s...).
            int hoursMax = (int)Math.Ceiling(max / 60.0);
            int step = hoursMax <= 4 ? 1 : (int)Math.Ceiling(hoursMax / 4.0);
            int niceHours = step * (int)Math.Ceiling(hoursMax / (double)step);
            yaxis = new YAxis
            {
                Min = 0,
                Max = niceHours * 60,
                TickAmount = niceHours / step,
                Labels = new YAxisLabels
                {
                    Style = new AxisLabelStyle { Colors = "#cbd5e1", FontSize = "11px" },
                    Formatter = "function (v) { return (v / 60) + 's'; }"
                }
            };
        }

        options.Yaxis = new List<YAxis> { yaxis };
    }

    /// <summary>
    /// DashboardBase.OnChartDataRefreshed tarafından çağrılır.
    /// ApexCharts'ın Blazor state değişimini kaçırdığı durumlarda DOM'u zorla günceller.
    /// </summary>
    public async Task ForceUpdateAsync()
    {
        if (chart != null)
        {
            await chart.UpdateSeriesAsync(true);
        }
    }
}
